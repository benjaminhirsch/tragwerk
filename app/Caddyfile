{
	frankenphp {
		worker {
			file ./public/index.php
			num {$FRANKENPHP_NUM_WORKERS:4}
		}
	}
	auto_https off
}

:80 {
	root * public/
	encode zstd br gzip

	route {
		mercure {
			publisher_jwt {env.MERCURE_PUBLISHER_JWT_SECRET}
			subscriber_jwt {env.MERCURE_SUBSCRIBER_JWT_SECRET}
			anonymous
			cors_origins *
		}

		php_server
	}
}
