<script src="/js/init-elements.js"></script>
<script nonce="<?= $this->e($this->cspNonce()) ?>">
    (function() {

        initElements('time[data-formatter="year-month"]', (element) => {
            element.textContent = new Date(`${element.dateTime}-01 00:00:00`)
                .toLocaleDateString(
                    document.documentElement.lang,
                    {year: 'numeric', month: 'long'},
                );
        });

        initElements('time[data-formatter="year-month-numerical"]', (element) => {
            element.textContent = new Date(`${element.dateTime}-01 00:00:00`)
                .toLocaleDateString(
                    document.documentElement.lang,
                    {year: 'numeric', month: '2-digit'},
                );
        });

        initElements('time[data-formatter="date"]', (element) => {
            element.textContent = new Date(`${element.dateTime} 00:00:00`)
                .toLocaleDateString(
                    document.documentElement.lang,
                    {year: 'numeric', month: 'long', day: 'numeric'},
                );
        });

        initElements('time[data-formatter="date-numerical"]', (element) => {
            element.textContent = new Date(`${element.dateTime} 00:00:00`)
                .toLocaleDateString(
                    document.documentElement.lang,
                    {year: 'numeric', month: '2-digit', day: '2-digit'},
                );
        });

        initElements('time[data-formatter="time"]', (element) => {
            element.textContent = new Date(`1970-01-01 ${element.dateTime}`)
                .toLocaleTimeString(
                    document.documentElement.lang,
                    {hour: '2-digit', minute: '2-digit'},
                );
        });

        initElements('time[data-formatter="time-numerical"]', (element) => {
            element.textContent = new Date(`1970-01-01 ${element.dateTime}`)
                .toLocaleTimeString(
                    document.documentElement.lang,
                    {hour: '2-digit', hour12: false, minute: '2-digit'},
                );
        });

        initElements('time[data-formatter="datetime"]', (element) => {
            element.textContent = new Date(element.dateTime)
                .toLocaleDateString(
                    document.documentElement.lang,
                    {year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit'},
                );
        });

        initElements('time[data-formatter="datetime-numerical"]', (element) => {
            element.textContent = new Date(element.dateTime)
                .toLocaleDateString(
                    document.documentElement.lang,
                    {
                        year: 'numeric',
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        hour12: false,
                        minute: '2-digit'
                    },
                );
        });

        initElements('time[data-formatter="relative"]', (element) => {
            const diffSeconds = Math.round((Date.now() - new Date(element.dateTime).getTime()) / 1000);
            const rtf = new Intl.RelativeTimeFormat(document.documentElement.lang, {numeric: 'auto'});
            const units = [
                ['year', 31536000],
                ['month', 2592000],
                ['day', 86400],
                ['hour', 3600],
                ['minute', 60],
            ];

            for (const [unit, seconds] of units) {
                if (Math.abs(diffSeconds) >= seconds) {
                    element.textContent = rtf.format(-Math.round(diffSeconds / seconds), unit);
                    return;
                }
            }

            element.textContent = rtf.format(-diffSeconds, 'second');
        });
    })();
</script>
