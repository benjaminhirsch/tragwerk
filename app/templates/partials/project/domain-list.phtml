<?php
/**
 * @var \Tragwerk\Domain\Entity\Project       $project
 * @var list<\Tragwerk\Domain\Entity\Domain>  $domains
 * @var string|null                           $error
 */
?>
<div id="domain-list">
    <?php if ($error !== null): ?>
        <div class="alert alert-danger py-2 mb-3">
            <i class="bi bi-exclamation-triangle me-1"></i><?= $this->e($error) ?>
        </div>
    <?php endif ?>

    <?php if ($domains === []): ?>
        <p class="text-body-secondary mb-0"><?= _('Noch keine Domains hinzugefügt.') ?></p>
    <?php else: ?>
        <ul class="list-group">
            <?php foreach ($domains as $domain): ?>
                <?php
                $deleteUrl  = $this->url('project.domain.delete', [
                    'id'       => $project->id->toString(),
                    'domainId' => $domain->id->toString(),
                ]);
                $primaryUrl = $this->url('project.domain.primary', [
                    'id'       => $project->id->toString(),
                    'domainId' => $domain->id->toString(),
                ]);
                ?>
                <li class="list-group-item d-flex align-items-center gap-2">
                    <i class="bi bi-globe text-body-secondary"></i>
                    <span class="flex-grow-1 font-monospace"><?= $this->e($domain->host) ?></span>

                    <?php if ($domain->isPrimary): ?>
                        <span class="badge bg-primary"><?= _('Primär') ?></span>
                    <?php else: ?>
                        <button class="btn btn-outline-secondary btn-sm"
                                hx-post="<?= $this->e($primaryUrl) ?>"
                                hx-target="#domain-list"
                                hx-swap="outerHTML">
                            <?= _('Als primär') ?>
                        </button>
                    <?php endif ?>

                    <button class="btn btn-outline-danger btn-sm"
                            hx-post="<?= $this->e($deleteUrl) ?>"
                            hx-target="#domain-list"
                            hx-swap="outerHTML"
                            hx-confirm="<?= $this->e(sprintf(_('Domain %s wirklich entfernen?'), $domain->host)) ?>">
                        <i class="bi bi-trash"></i>
                    </button>
                </li>
            <?php endforeach ?>
        </ul>
    <?php endif ?>
</div>
