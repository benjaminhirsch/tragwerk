<?php
/**
 * @var \Tragwerk\Domain\Entity\Project              $project
 * @var list<\Tragwerk\Domain\Entity\ProjectWebhook> $integrations
 * @var list<\Tragwerk\Domain\Enum\GitForge>         $availableForges
 * @var string                                       $baseUrl
 * @var string|null                                  $error
 */
?>
<div id="webhook-list">
    <?php if ($error !== null): ?>
        <div class="alert alert-danger py-2 mb-3">
            <i class="bi bi-exclamation-triangle me-1"></i><?= $this->e($error) ?>
        </div>
    <?php endif ?>

    <?php if ($integrations === []): ?>
        <p class="text-body-secondary mb-3"><?= $this->t('No integrations configured yet.') ?></p>
    <?php else: ?>
        <div class="list-group mb-3">
            <?php foreach ($integrations as $integration): ?>
                <?php
                $webhookUrl = $baseUrl . '/webhooks/' . $integration->forge->value . '/' . $project->id->toString();
                $deleteUrl  = $this->url('project.webhook.delete', [
                    'id'        => $project->id->toString(),
                    'webhookId' => $integration->id->toString(),
                ]);
                $forgeLabel = match ($integration->forge) {
                    \Tragwerk\Domain\Enum\GitForge::GITHUB    => 'GitHub',
                    \Tragwerk\Domain\Enum\GitForge::GITLAB    => 'GitLab',
                    \Tragwerk\Domain\Enum\GitForge::FORGEJO   => 'Forgejo',
                    \Tragwerk\Domain\Enum\GitForge::GITEA     => 'Gitea',
                    \Tragwerk\Domain\Enum\GitForge::CODEBERG  => 'Codeberg',
                    \Tragwerk\Domain\Enum\GitForge::BITBUCKET => 'Bitbucket',
                };
                ?>
                <div class="list-group-item">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="fw-semibold"><i class="bi bi-link-45deg me-1"></i><?= $this->e($forgeLabel) ?></span>
                        <button class="btn btn-outline-danger btn-sm"
                                hx-post="<?= $this->e($deleteUrl) ?>"
                                hx-target="#webhook-list"
                                hx-swap="outerHTML"
                                hx-include="#tw-csrf-token"
                                hx-confirm="<?= $this->e($this->t('Remove this integration?')) ?>">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                    <div class="mb-1">
                        <label class="form-label small text-body-secondary mb-1"><?= $this->t('Webhook URL') ?></label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="bi bi-link"></i></span>
                            <input type="text" class="form-control font-monospace"
                                   value="<?= $this->e($webhookUrl) ?>" readonly onclick="this.select()">
                        </div>
                    </div>
                    <div>
                        <label class="form-label small text-body-secondary mb-1"><?= $this->t('Secret') ?></label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="bi bi-key"></i></span>
                            <input type="text" class="form-control font-monospace"
                                   value="<?= $this->e($integration->secret) ?>" readonly onclick="this.select()">
                        </div>
                    </div>
                </div>
            <?php endforeach ?>
        </div>
    <?php endif ?>

    <?php if ($availableForges !== []): ?>
        <form hx-post="<?= $this->url('project.webhook.create', ['id' => $project->id->toString()]) ?>"
              hx-target="#webhook-list"
              hx-swap="outerHTML"
              hx-include="#tw-csrf-token">
            <div class="d-flex gap-2 align-items-end">
                <div class="flex-grow-1">
                    <label class="form-label small"><?= $this->t('Add integration') ?></label>
                    <select name="forge" class="form-select form-select-sm">
                        <?php foreach ($availableForges as $forge): ?>
                            <?php
                            $label = match ($forge) {
                                \Tragwerk\Domain\Enum\GitForge::GITHUB    => 'GitHub',
                                \Tragwerk\Domain\Enum\GitForge::GITLAB    => 'GitLab',
                                \Tragwerk\Domain\Enum\GitForge::FORGEJO   => 'Forgejo',
                                \Tragwerk\Domain\Enum\GitForge::GITEA     => 'Gitea',
                                \Tragwerk\Domain\Enum\GitForge::CODEBERG  => 'Codeberg',
                                \Tragwerk\Domain\Enum\GitForge::BITBUCKET => 'Bitbucket',
                            };
                            ?>
                            <option value="<?= $this->e($forge->value) ?>"><?= $this->e($label) ?></option>
                        <?php endforeach ?>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-lg me-1"></i><?= $this->t('Add') ?>
                </button>
            </div>
        </form>
    <?php else: ?>
        <p class="text-body-secondary small mb-0">
            <i class="bi bi-check-circle me-1"></i><?= $this->t('All supported forges are configured.') ?>
        </p>
    <?php endif ?>
</div>
