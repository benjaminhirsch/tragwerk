<?php

use Tragwerk\Domain\Enum\TeamRole;

/** @var \Tragwerk\Domain\Entity\TeamInvitation[] $invitations */
$invitations = $invitations ?? [];
?>
<?php if ($invitations !== []): ?>
    <div class="mt-3">
        <h3 style="font-size:.95rem;margin:0 0 .4rem"><?= $this->e($this->t('Pending invitations')) ?></h3>
        <div class="tw-table-wrap">
            <table class="tw-table">
                <tbody>
                <?php foreach ($invitations as $invitation): ?>
                    <?php
                    [$roleLabel, $roleClass] = match ($invitation->role) {
                        TeamRole::Owner  => [$this->t('Owner'), 'tw-badge--info'],
                        TeamRole::Admin  => [$this->t('Admin'), 'tw-badge--warn'],
                        TeamRole::Member => [$this->t('Member'), 'tw-badge--neutral'],
                    };
                    ?>
                    <tr>
                        <td>
                            <span class="tw-cell-strong"><?= $this->e($invitation->email) ?></span>
                            <span class="text-faint" style="font-size:.76rem"> · <?= $this->e($this->t('invited')) ?></span>
                        </td>
                        <td class="text-end">
                            <span class="tw-badge <?= $roleClass ?>"><span class="tw-dot"></span><?= $this->e($roleLabel) ?></span>
                        </td>
                    </tr>
                <?php endforeach ?>
                </tbody>
            </table>
        </div>
    </div>
<?php endif ?>
