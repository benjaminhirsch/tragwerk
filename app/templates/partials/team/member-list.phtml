<?php

use Tragwerk\Domain\Enum\TeamRole;

/** @var \Tragwerk\Domain\ValueObject\TeamMembership[] $memberships */
/** @var string[] $usersToRemove */
/** @var string $teamId */
/** @var bool $canManage */
/** @var bool $actorIsOwner */
$memberships   = $memberships ?? [];
$usersToRemove = $usersToRemove ?? [];
$teamId        = $teamId ?? '';
$canManage     = $canManage ?? false;
$actorIsOwner  = $actorIsOwner ?? false;
?>
<div id="tw-member-list" class="tw-table-wrap">
    <?php foreach ($usersToRemove as $removedId): ?>
        <input type="hidden" name="usersToRemove[]" value="<?= $this->e($removedId) ?>">
    <?php endforeach ?>

    <table class="tw-table">
        <thead>
        <tr>
            <th><?= $this->e($this->t('Member')) ?></th>
            <th><?= $this->e($this->t('Role')) ?></th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        <?php if ($memberships === []): ?>
            <tr>
                <td colspan="3" class="tw-cell-muted"><?= $this->e($this->t('No members in this team.')) ?></td>
            </tr>
        <?php else: ?>
            <?php foreach ($memberships as $membership): ?>
                <?php
                $member  = $membership->user;
                $role    = $membership->role;
                $isOwner = $role === TeamRole::Owner;
                [$roleLabel, $roleClass] = match ($role) {
                    TeamRole::Owner  => [$this->t('Owner'), 'tw-badge--info'],
                    TeamRole::Admin  => [$this->t('Admin'), 'tw-badge--warn'],
                    TeamRole::Member => [$this->t('Member'), 'tw-badge--neutral'],
                };
                ?>
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <span class="tw-ava" style="width:32px;height:32px;border-radius:8px;font-size:.72rem;background:<?= $member->abbreviation()->oklch() ?>">
                                <?= $this->e($member->abbreviation()->forString()) ?>
                            </span>
                            <div>
                                <div class="tw-cell-strong"><?= $this->e($member->fullName()) ?></div>
                                <div class="text-faint" style="font-size:.76rem"><?= $this->e($member->email) ?></div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <?php if ($canManage && ! $isOwner): ?>
                            <select class="form-select form-select-sm" style="width:auto;display:inline-block"
                                    name="role"
                                    title="<?= $this->e($this->t('Role')) ?>"
                                    hx-post="<?= $this->url('team.members.role', ['id' => $teamId]) ?>"
                                    hx-target="#tw-member-list"
                                    hx-swap="outerHTML"
                                    hx-trigger="change"
                                    hx-include="[name='csrf_token']"
                                    hx-vals='{"userId": "<?= $this->e($member->id->toString()) ?>"}'>
                                <option value="<?= TeamRole::Member->value ?>"<?= $role === TeamRole::Member ? ' selected' : '' ?>><?= $this->e($this->t('Member')) ?></option>
                                <option value="<?= TeamRole::Admin->value ?>"<?= $role === TeamRole::Admin ? ' selected' : '' ?>><?= $this->e($this->t('Admin')) ?></option>
                                <?php if ($actorIsOwner): ?>
                                    <option value="<?= TeamRole::Owner->value ?>"><?= $this->e($this->t('Make owner')) ?></option>
                                <?php endif ?>
                            </select>
                        <?php else: ?>
                            <span class="tw-badge <?= $roleClass ?>"><span class="tw-dot"></span><?= $this->e($roleLabel) ?></span>
                        <?php endif ?>
                    </td>
                    <td class="text-end">
                        <?php if ($canManage && ! $isOwner): ?>
                            <?= $this->fetch('partial::input/button', [
                                'classes'   => 'btn btn-ghost btn-sm btn-del',
                                'icon'      => 'bi bi-trash3',
                                'title'     => $this->t('Remove member'),
                                'hxPost'    => $this->url('team.members.remove', ['id' => $teamId]),
                                'hxTarget'  => '#tw-member-list',
                                'hxSwap'    => 'outerHTML',
                                'hxInclude' => 'closest form',
                                'hxVals'    => '{"userId": "' . $this->e($member->id->toString()) . '"}',
                                'label'     => '',
                                'type'      => 'button',
                            ]) ?>
                        <?php endif ?>
                    </td>
                </tr>
            <?php endforeach ?>
        <?php endif ?>
        </tbody>
    </table>
</div>
