<?php
$currentPath = parse_url($_SERVER['REQUEST_URI'] ?? '/', PHP_URL_PATH) ?? '/';

$links = [
        [
                'include' => 'partial::link',
                'label' => _('Servers'),
                'href' => $this->url('server'),
                'classes' => 'nav-link bi bi-hdd-stack',
        ],
        [
                'include' => 'partial::link',
                'label' => _('Credentials'),
                'href' => $this->url('credential'),
                'classes' => 'nav-link bi bi-key',
        ],
        [
                'include' => 'partial::link',
                'label' => _('Teams'),
                'href' => $this->url('team'),
                'classes' => 'nav-link bi bi-people',
        ],
        [
                'include' => 'partial::link',
                'label' => _('Projects'),
                'href' => $this->url('project'),
                'classes' => 'nav-link bi bi-folder',
        ],
        [
                'include' => 'partial::link',
                'label' => _('Queue'),
                'href' => $this->url('queue'),
                'classes' => 'nav-link bi bi-list-task',
        ],
];

foreach ($links as &$l) {
    $linkPath = parse_url($l['href'], PHP_URL_PATH) ?? $l['href'];
    if (str_starts_with($currentPath, $linkPath)) {
        $l['classes'] .= ' active';
    }
}
unset($l);
$teams      = $this->userTeams();
$activeTeam = $this->activeTeam();
?>
<?php if (count($teams) > 1): ?>
<div class="tw-project-switcher px-2 pb-3">
    <form id="tw-team-switch-form">
        <input type="hidden" name="csrf_token" value="<?= $this->getCsrfToken() ?>">
        <?= $this->fetch('partial::input/select', [
            'id' => 'teamId',
            'classes' => 'form-select form-select-sm',
            'hxPost' => $this->url('team.switch'),
            'hxTrigger' => 'change',
            'hxInclude' => 'closest form',
            'hxSwap' => 'none',
            'disableEmptyOption' => true,
            'options' => array_combine(
                    array_map(fn($p) => $p->id->toString(), $teams),
                    array_map(fn($p) => $p->name, $teams)
            ),
            'defaultValue' => $activeTeam?->id->toString(),
        ]) ?>
    </form>
</div>
<?php endif; ?>
<ul class="nav flex-column">
    <?php foreach ($links as $l) printf('%s', $this->fetch($l['include'], $l));  ?>
</ul>
