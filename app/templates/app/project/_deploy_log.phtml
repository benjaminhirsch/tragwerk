<?php
/**
 * @var \Tragwerk\Domain\Entity\Project            $project
 * @var string                                     $branch
 * @var list<\Tragwerk\Domain\Entity\DeployJob>    $jobs
 * @var list<\Tragwerk\Domain\Entity\DeployJob>    $activeJobs
 * @var int                                        $offset
 * @var bool                                       $hasMore
 * @var bool                                       $forcePolling
 */
$logUrl   = $this->url('project.environment.deploy-log', ['id' => $project->id->toString()])
    . '?branch=' . urlencode($branch);
$polling  = $forcePolling || $activeJobs !== [];
?>
<div id="tw-deploy-log"
    <?php if ($polling): ?>
    hx-get="<?= $this->e($logUrl) ?>"
    hx-trigger="every 2s"
    hx-swap="outerHTML"
    <?php endif ?>
>
    <?php if ($jobs === []): ?>
        <div class="text-body-secondary small">
            <i class="bi bi-info-circle me-1"></i>
            <?= $this->t('No deploys yet.') ?>
        </div>
    <?php else: ?>
        <div class="list-group list-group-flush border rounded" id="tw-deploy-job-list">
            <?= $this->fetch('page::project/_deploy_log_items', [
                'project' => $project,
                'branch'  => $branch,
                'jobs'    => $jobs,
                'offset'  => $offset,
                'hasMore' => $hasMore,
            ]) ?>
        </div>
    <?php endif ?>
</div>
