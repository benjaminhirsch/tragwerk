<?php

declare(strict_types=1);

/**
 * @var \Tragwerk\Domain\Entity\Project                $project
 * @var string                                         $branch
 * @var \Tragwerk\Domain\Model\EnvironmentMetrics|null $metrics
 * @var string|null                                    $error
 */

$liveUrl = $this->url('project.environment.metrics-live', ['id' => $project->id->toString()])
    . '?branch=' . urlencode($branch);

$stat = function (int $value, string $label) {
    return '<div class="col-6 col-md-3">'
        . '<div class="border rounded p-2 h-100">'
        . '<div class="fs-5 fw-semibold">' . $this->e((string) $value) . '</div>'
        . '<div class="text-body-secondary" style="font-size:.75rem">' . $this->e($label) . '</div>'
        . '</div></div>';
};
?>
<div hx-get="<?= $this->e($liveUrl) ?>"
     hx-trigger="every 15s"
     hx-target="#tw-app-metrics"
     hx-swap="innerHTML">
    <?php if ($error !== null): ?>
        <div class="d-flex align-items-center gap-2 text-body-secondary small">
            <i class="bi bi-exclamation-triangle text-warning flex-shrink-0"></i>
            <span><?= $this->e($error) ?></span>
        </div>
    <?php elseif ($metrics === null): ?>
        <div class="text-body-secondary small">
            <i class="bi bi-info-circle me-1"></i>
            <?= $this->t('No FrankenPHP worker metrics available — environment is not running or not in worker mode.') ?>
        </div>
    <?php else: ?>
        <?php $busyPct = $metrics->totalWorkers > 0 ? ($metrics->busyWorkers / $metrics->totalWorkers) * 100 : 0.0; ?>
        <div class="mb-3">
            <div class="d-flex justify-content-between small mb-1">
                <span class="fw-medium"><?= $this->t('Workers busy') ?></span>
                <span class="text-body-secondary">
                    <?= $this->e($metrics->busyWorkers . ' / ' . $metrics->totalWorkers) ?>
                </span>
            </div>
            <div class="progress" role="progressbar" style="height:.5rem">
                <div class="progress-bar bg-primary" style="width:<?= round(max(0.0, min(100.0, $busyPct)), 1) ?>%"></div>
            </div>
        </div>

        <div class="row g-2">
            <?= $stat($metrics->readyWorkers, $this->t('Ready workers')) ?>
            <?= $stat($metrics->queueDepth, $this->t('Queue depth')) ?>
            <?= $stat($metrics->inFlight, $this->t('In-flight requests')) ?>
            <?= $stat($metrics->requestsTotal, $this->t('HTTP requests')) ?>
            <?= $stat($metrics->crashes, $this->t('Crashes')) ?>
            <?= $stat($metrics->restarts, $this->t('Restarts')) ?>
        </div>
    <?php endif ?>
</div>
