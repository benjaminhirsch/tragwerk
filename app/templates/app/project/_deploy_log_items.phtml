<?php
/**
 * @var \Tragwerk\Domain\Entity\Project            $project
 * @var string                                     $branch
 * @var list<\Tragwerk\Domain\Entity\DeployJob>    $jobs
 * @var int                                        $offset
 * @var bool                                       $hasMore
 */
$logUrl     = $this->url('project.environment.deploy-log', ['id' => $project->id->toString()])
    . '?branch=' . urlencode($branch);
$nextOffset = $offset + count($jobs);
?>
<?php foreach ($jobs as $job): ?>
    <?php
    $outputUrl = $this->url('project.environment.deploy-job-output', [
        'id'    => $project->id->toString(),
        'jobId' => $job->id->toString(),
    ]);
    $isActive = $job->status->value === 'pending' || $job->status->value === 'running';
    ?>
    <?php
    $diff    = $job->createdAt->toDateTime()->diff($job->updatedAt->toDateTime());
    $seconds = $diff->days * 86400 + $diff->h * 3600 + $diff->i * 60 + $diff->s;
    $duration = $seconds >= 60
        ? sprintf('%dm %ds', intdiv($seconds, 60), $seconds % 60)
        : $seconds . 's';
    $showDuration = $job->status->value === 'completed' || $job->status->value === 'failed';
    ?>
    <div class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2"
         style="cursor:pointer"
         hx-get="<?= $this->e($outputUrl) ?>"
         hx-target="#tw-job-modal-body"
         hx-swap="innerHTML"
         hx-on:htmx:after-request="bootstrap.Modal.getOrCreateInstance(document.getElementById('tw-job-modal')).show()"
    >
        <div class="flex-shrink-0" style="width:1.25rem;text-align:center">
            <?php if ($job->status->value === 'completed'): ?>
                <i class="bi bi-check-circle-fill text-success"></i>
            <?php elseif ($job->status->value === 'failed'): ?>
                <i class="bi bi-x-circle-fill text-danger"></i>
            <?php elseif ($job->status->value === 'running'): ?>
                <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
            <?php else: ?>
                <span class="spinner-border spinner-border-sm text-secondary" role="status"></span>
            <?php endif ?>
        </div>
        <div class="flex-grow-1 overflow-hidden">
            <div class="small fw-medium">
                <?php if ($job->commitSha !== ''): ?>
                    <code><?= $this->e(substr($job->commitSha, 0, 7)) ?></code>
                <?php else: ?>
                    <span class="text-body-secondary"><?= $this->t('(sync)') ?></span>
                <?php endif ?>
            </div>
            <div class="text-body-secondary" style="font-size:.75rem">
                <?= $this->e($job->createdAt->format('Y-m-d H:i')) ?>
                <?php if ($showDuration): ?>
                    &middot; <?= $this->e($duration) ?>
                <?php endif ?>
            </div>
        </div>
        <div class="flex-shrink-0">
            <?php if ($job->status->value === 'completed'): ?>
                <span class="badge bg-success-subtle text-success border border-success-subtle">
                    <?= $this->t('Completed') ?>
                </span>
            <?php elseif ($job->status->value === 'failed'): ?>
                <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                    <?= $this->t('Failed') ?>
                </span>
            <?php elseif ($job->status->value === 'running'): ?>
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                    <?= $this->t('Running') ?>
                </span>
            <?php else: ?>
                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                    <?= $this->t('Pending') ?>
                </span>
            <?php endif ?>
        </div>
    </div>
<?php endforeach ?>
<?php if ($hasMore): ?>
<div hx-get="<?= $this->e($logUrl . '&offset=' . $nextOffset) ?>"
     hx-trigger="revealed"
     hx-target="this"
     hx-swap="outerHTML">
</div>
<?php endif ?>
