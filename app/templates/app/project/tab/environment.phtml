<?php
/**
 * @var \Tragwerk\Domain\Entity\Project         $project
 * @var string                                  $branch
 * @var \Tragwerk\Infrastructure\Git\Commit[]   $commits
 * @var \Tragwerk\Domain\Entity\BuildLog[]       $buildLogs
 * @var bool                                    $isActive
 * @var bool                                    $isProtected
 * @var \Tragwerk\Domain\Model\ProjectConfig|null $projectConfig
 */
$tabId     = 'tw-env-tab-' . md5($branch);
$deployUrl = $this->url('project.environment.deploy-log', ['id' => $project->id->toString()])
    . '?branch=' . urlencode($branch);
?>
<ul class="nav nav-tabs nav-tabs-sm mb-3" id="<?= $tabId ?>" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="<?= $tabId ?>-deploy-tab"
                data-bs-toggle="tab" data-bs-target="#<?= $tabId ?>-deploy"
                type="button" role="tab">
            <?= _('Deploy Log') ?>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="<?= $tabId ?>-log-tab"
                data-bs-toggle="tab" data-bs-target="#<?= $tabId ?>-log"
                type="button" role="tab">
            <?= _('Build-Log') ?>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="<?= $tabId ?>-config-tab"
                data-bs-toggle="tab" data-bs-target="#<?= $tabId ?>-config"
                type="button" role="tab">
            <?= _('Konfiguration') ?>
        </button>
    </li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade show active" id="<?= $tabId ?>-deploy" role="tabpanel">
        <div hx-get="<?= $this->e($deployUrl) ?>"
             hx-trigger="load"
             hx-swap="outerHTML">
        </div>
    </div>

    <div class="tab-pane fade" id="<?= $tabId ?>-log" role="tabpanel">
        <?php if ($buildLogs !== []): ?>
            <h6 class="text-body-secondary small text-uppercase fw-semibold mb-2 mt-1">
                <?= _('Build Log') ?>
            </h6>
            <ul class="list-unstyled mb-4">
                <?php foreach ($buildLogs as $log): ?>
                    <li class="d-flex gap-3 py-2 border-bottom">
                        <div class="flex-shrink-0 mt-1">
                            <?php $icon = match ($log->type->value) {
                                'PUSH'    => 'bi-arrow-up-circle text-primary',
                                'BUILD'   => 'bi-hammer text-success',
                                'WEBHOOK' => 'bi-plug text-info',
                                'CRONJOB' => 'bi-clock text-warning',
                                default   => 'bi-gear text-secondary',
                            } ?>
                            <i class="bi <?= $icon ?>"></i>
                        </div>
                        <div class="flex-grow-1 overflow-hidden">
                            <div class="small text-body-secondary">
                                <span class="badge bg-secondary me-1"><?= $this->e($log->type->value) ?></span>
                                <span title="<?= $this->e($log->createdAt->format('Y-m-d H:i:s')) ?>">
                                    <?= $this->e($log->createdAt->format('Y-m-d H:i')) ?>
                                </span>
                            </div>
                            <pre class="mb-0 mt-1 small text-body-secondary" style="white-space: pre-wrap; word-break: break-word;"><?= $this->e($log->message) ?></pre>
                        </div>
                    </li>
                <?php endforeach ?>
            </ul>
        <?php endif ?>

        <?php if ($commits !== []): ?>
            <h6 class="text-body-secondary small text-uppercase fw-semibold mb-2">
                <?= _('Commits') ?>
            </h6>
            <ul class="list-unstyled mb-0">
                <?php foreach ($commits as $commit): ?>
                    <li class="d-flex gap-3 py-2 border-bottom">
                        <div class="flex-shrink-0 mt-1">
                            <i class="bi bi-git text-body-secondary"></i>
                        </div>
                        <div class="flex-grow-1 overflow-hidden">
                            <div class="fw-medium text-truncate"><?= $this->e($commit->subject) ?></div>
                            <div class="small text-body-secondary">
                                <?= $this->e($commit->authorName) ?>
                                &middot;
                                <span title="<?= $this->e($commit->committedAt->format('Y-m-d H:i:s')) ?>">
                                    <?= $this->e($commit->committedAt->format('Y-m-d H:i')) ?>
                                </span>
                            </div>
                        </div>
                        <div class="flex-shrink-0">
                            <code class="small text-body-secondary"><?= $this->e($commit->shortHash) ?></code>
                        </div>
                    </li>
                <?php endforeach ?>
            </ul>
        <?php elseif ($buildLogs === []): ?>
            <div class="text-body-secondary">
                <i class="bi bi-info-circle me-1"></i>
                <?= _('No commits on this branch yet.') ?>
            </div>
        <?php endif ?>
    </div>

    <div class="tab-pane fade" id="<?= $tabId ?>-config" role="tabpanel">
        <?php if ($projectConfig === null): ?>
            <div class="text-body-secondary">
                <i class="bi bi-file-earmark-x me-1"></i>
                <?= _('No .tragwerk/config.xml found on this branch.') ?>
            </div>
        <?php else: ?>
            <div class="mb-3">
                <a href="<?= $this->url('project.environment.download', ['id' => $project->id->toString()]) ?>?branch=<?= urlencode($branch) ?>"
                   class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-download me-1"></i><?= _('Docker-Konfiguration herunterladen') ?>
                </a>
            </div>
            <?php if ($projectConfig->applications !== []): ?>
                <h6 class="text-body-secondary small text-uppercase fw-semibold mb-2 mt-1">
                    <?= _('Applications') ?>
                </h6>
                <?php foreach ($projectConfig->applications as $app): ?>
                    <div class="card mb-3">
                        <div class="card-body py-2 px-3">
                            <div class="fw-semibold mb-1"><?= $this->e($app->name) ?></div>
                            <div class="small text-body-secondary mb-1">
                                <span class="badge bg-secondary me-1"><?= $this->e($app->type->value) ?></span>
                                <?php if ($app->root !== '/'): ?>
                                    <code class="small"><?= $this->e($app->root) ?></code>
                                <?php endif ?>
                            </div>
                            <?php if ($app->mounts !== []): ?>
                                <div class="small mt-2">
                                    <span class="text-body-secondary"><?= _('Mounts:') ?></span>
                                    <?php foreach ($app->mounts as $mount): ?>
                                        <code class="ms-1"><?= $this->e($mount->path) ?></code>
                                    <?php endforeach ?>
                                </div>
                            <?php endif ?>
                            <?php if ($app->relationships !== []): ?>
                                <div class="small mt-1">
                                    <span class="text-body-secondary"><?= _('Relationships:') ?></span>
                                    <?php foreach ($app->relationships as $rel): ?>
                                        <span class="ms-1"><code><?= $this->e($rel->name) ?></code> → <code><?= $this->e($rel->target) ?></code></span>
                                    <?php endforeach ?>
                                </div>
                            <?php endif ?>
                            <?php if ($app->hooks !== []): ?>
                                <div class="small mt-1">
                                    <span class="text-body-secondary"><?= _('Hooks:') ?></span>
                                    <?php foreach ($app->hooks as $hook): ?>
                                        <span class="badge bg-light text-dark ms-1"><?= $this->e($hook->type->value) ?></span>
                                    <?php endforeach ?>
                                </div>
                            <?php endif ?>
                        </div>
                    </div>
                <?php endforeach ?>
            <?php endif ?>

            <?php if ($projectConfig->services !== []): ?>
                <h6 class="text-body-secondary small text-uppercase fw-semibold mb-2">
                    <?= _('Services') ?>
                </h6>
                <ul class="list-unstyled mb-3">
                    <?php foreach ($projectConfig->services as $service): ?>
                        <li class="d-flex align-items-center gap-2 py-1 border-bottom">
                            <i class="bi bi-database text-body-secondary flex-shrink-0"></i>
                            <span class="fw-medium"><?= $this->e($service->name) ?></span>
                            <span class="badge bg-secondary ms-auto"><?= $this->e($service->type->value) ?></span>
                        </li>
                    <?php endforeach ?>
                </ul>
            <?php endif ?>

            <?php if ($projectConfig->routes !== []): ?>
                <h6 class="text-body-secondary small text-uppercase fw-semibold mb-2">
                    <?= _('Routes') ?>
                </h6>
                <ul class="list-unstyled mb-0">
                    <?php foreach ($projectConfig->routes as $route): ?>
                        <li class="d-flex align-items-center gap-2 py-1 border-bottom small">
                            <i class="bi bi-arrow-right text-body-secondary flex-shrink-0"></i>
                            <code class="text-truncate flex-grow-1"><?= $this->e($route->pattern) ?></code>
                            <span class="badge bg-secondary ms-auto flex-shrink-0"><?= $this->e($route->type->value) ?></span>
                        </li>
                    <?php endforeach ?>
                </ul>
            <?php endif ?>
        <?php endif ?>
    </div>
</div>
