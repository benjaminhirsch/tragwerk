<?php
/**
 * @var \Tragwerk\Domain\Entity\Project            $project
 * @var \Tragwerk\Domain\Entity\Server             $server
 * @var \Tragwerk\Domain\Entity\Team               $team
 * @var \Tragwerk\Domain\Entity\Registry|null      $registry
 * @var list<\Tragwerk\Domain\Entity\SwarmNode>    $swarmNodes
 * @var bool                                       $swarmDeployed
 * @var list<\Tragwerk\Domain\Entity\Server>       $swarmAvailable
 * @var array<string, string>                      $swarmServerNames
 * @var string                                     $cloneUrl
 */
?>
<table class="table table-borderless mb-0">
    <tbody>
        <tr>
            <th class="w-25 text-body-secondary fw-normal"><?= $this->t('Name') ?></th>
            <td><?= $this->e($project->name) ?></td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= $this->t('Server') ?></th>
            <td>
                <?= $this->fetch('partial::link', [
                    'href'  => $this->url('server.show', ['id' => $server->id->toString()]),
                    'label' => $server->name,
                ]) ?>
                <?php if ($project->swarmEnabled): ?>
                    <span class="badge bg-info ms-1"><?= $this->t('Swarm Manager') ?></span>
                <?php endif ?>
            </td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= $this->t('Container registry') ?></th>
            <td>
                <?php if ($registry !== null): ?>
                    <?= $this->fetch('partial::link', [
                        'href'  => $this->url('registry.edit', ['id' => $registry->id->toString()]),
                        'label' => $registry->name,
                    ]) ?>
                    <span class="text-body-secondary small ms-1">(<?= $this->e($registry->url) ?>)</span>
                <?php else: ?>
                    <span class="text-body-secondary"><?= $this->t('None — builds on server') ?></span>
                <?php endif ?>
            </td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= $this->t('Team') ?></th>
            <td>
                <?= $this->fetch('partial::link', [
                    'href'  => $this->url('team.show', ['id' => $team->id->toString()]),
                    'label' => $team->name,
                ]) ?>
            </td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= $this->t('Created') ?></th>
            <td><?= $this->e($project->createdAt->format('Y-m-d H:i')) ?></td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= $this->t('Updated') ?></th>
            <td><?= $this->e($project->updatedAt->format('Y-m-d H:i')) ?></td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= $this->t('Git clone URL') ?></th>
            <td>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-git"></i></span>
                    <input type="text" class="form-control form-control-sm font-monospace"
                           value="<?= $this->e($cloneUrl) ?>" readonly onclick="this.select()">
                </div>
            </td>
        </tr>
    </tbody>
</table>

<?php if ($project->swarmEnabled): ?>
    <hr>
    <h6 class="text-body-secondary mb-2">
        <i class="bi bi-diagram-3"></i> <?= $this->t('Docker Swarm Cluster') ?>
    </h6>
    <?= $this->fetch('partial::project/swarm-nodes', [
        'project'     => $project,
        'nodes'       => $swarmNodes,
        'deployed'    => $swarmDeployed,
        'available'   => $swarmAvailable,
        'serverNames' => $swarmServerNames,
        'error'       => null,
    ]) ?>
<?php endif ?>
