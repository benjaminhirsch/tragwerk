<?php
/**
 * @var \Tragwerk\Domain\Entity\Project    $project
 * @var list<\Tragwerk\Domain\Entity\Domain> $domains
 */
$addUrl = $this->url('project.domain.add', ['id' => $project->id->toString()]);
?>

<form hx-post="<?= $this->e($addUrl) ?>"
      hx-target="#domain-list"
      hx-swap="outerHTML"
      class="mb-4">
    <input type="hidden" id="tw-csrf-token" name="csrf_token" value="<?= $this->getCsrfToken() ?>">
    <label class="form-label"><?= _('Domain hinzufügen') ?></label>
    <input type="text"
           name="host"
           class="form-control mb-2"
           placeholder="example.com"
           required>
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i><?= _('Hinzufügen') ?>
    </button>
</form>

<?= $this->fetch('partial::project/domain-list', [
    'project' => $project,
    'domains' => $domains,
    'error'   => null,
]) ?>
