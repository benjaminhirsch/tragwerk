<?php
/**
 * @var \Tragwerk\Domain\Entity\Project $project
 * @var string[]                        $branches
 * @var string                          $cloneUrl
 */
?>
<div class="mb-3">
    <label class="form-label text-body-secondary small mb-1"><?= _('Git clone URL') ?></label>
    <div class="input-group input-group-sm">
        <span class="input-group-text"><i class="bi bi-git"></i></span>
        <input type="text" class="form-control font-monospace" value="<?= $this->e($cloneUrl) ?>" readonly
               onclick="this.select()">
    </div>
</div>

<?php if ($branches === []): ?>
    <div class="text-body-secondary">
        <i class="bi bi-info-circle me-1"></i>
        <?= _('No branches yet. Push your first commit to get started.') ?>
    </div>
<?php else: ?>
    <div class="list-group list-group-flush" id="environment-branch-list">
        <?php foreach ($branches as $branch): ?>
            <button type="button"
                    class="list-group-item list-group-item-action d-flex align-items-center gap-2"
                    hx-get="<?= $this->url('project.environment', ['id' => $project->id->toString()]) ?>?branch=<?= urlencode($branch) ?>"
                    hx-target="#environment-activities"
                    hx-swap="innerHTML"
                    hx-on:click="document.querySelectorAll('#environment-branch-list .list-group-item').forEach(el => el.classList.remove('active')); this.classList.add('active')">
                <i class="bi bi-diagram-2 text-body-secondary"></i>
                <?= $this->e($branch) ?>
            </button>
        <?php endforeach ?>
    </div>

    <div id="environment-activities" class="mt-3 text-body-secondary">
        <?= _('Select a branch to view its activity.') ?>
    </div>
<?php endif ?>
