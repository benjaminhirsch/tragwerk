<?php

declare(strict_types=1);

/**
 * @var \Tragwerk\Domain\Entity\Project                                        $project
 * @var string                                                                  $branch
 * @var string                                                                  $level
 * @var list<array{time: string, level: string, logger: string, msg: string, raw: string}> $entries
 * @var string|null                                                             $error
 */

$logsUrl = $this->url('project.environment.logs', ['id' => $project->id->toString()])
    . '?branch=' . urlencode($branch)
    . '&level=' . urlencode($level);

$levelUrl = fn (string $l): string => $this->url('project.environment.logs', ['id' => $project->id->toString()])
    . '?branch=' . urlencode($branch)
    . '&level=' . urlencode($l);

$levelBadge = static function (string $lvl): string {
    return match ($lvl) {
        'error'  => '<span class="badge bg-danger-subtle text-danger border border-danger-subtle" style="font-size:.7rem">error</span>',
        'warn'   => '<span class="badge bg-warning-subtle text-warning border border-warning-subtle" style="font-size:.7rem">warn</span>',
        'info'   => '<span class="badge bg-primary-subtle text-primary border border-primary-subtle" style="font-size:.7rem">info</span>',
        'debug'  => '<span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle" style="font-size:.7rem">debug</span>',
        default  => '<span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle" style="font-size:.7rem">' . htmlspecialchars($lvl) . '</span>',
    };
};

$levels = ['all', 'debug', 'info', 'warn', 'error'];
?>
<div id="tw-environment-logs"
     hx-get="<?= $this->e($logsUrl) ?>"
     hx-trigger="every 5s"
     hx-target="#tw-environment-logs"
     hx-swap="outerHTML">

    <div class="d-flex align-items-center justify-content-between gap-2 mb-3">
        <div class="btn-group btn-group-sm" role="group">
            <?php foreach ($levels as $l): ?>
                <a href="#"
                   class="btn <?= $level === $l ? 'btn-secondary' : 'btn-outline-secondary' ?>"
                   hx-get="<?= $this->e($levelUrl($l)) ?>"
                   hx-target="#tw-environment-logs"
                   hx-swap="outerHTML">
                    <?= $this->e(ucfirst($l)) ?>
                </a>
            <?php endforeach ?>
        </div>
        <span class="text-body-secondary small">
            <?= count($entries) ?> <?= $this->t('entries') ?>
            &middot; last 500 lines &middot; auto-refresh 5s
        </span>
    </div>

    <?php if ($error !== null): ?>
        <div class="d-flex align-items-center gap-2 text-body-secondary small">
            <i class="bi bi-exclamation-triangle text-warning flex-shrink-0"></i>
            <span><?= $this->e($error) ?></span>
        </div>
    <?php elseif ($entries === []): ?>
        <div class="text-body-secondary small">
            <i class="bi bi-info-circle me-1"></i>
            <?= $this->t('No log entries.') ?>
        </div>
    <?php else: ?>
        <div class="table-responsive" style="max-height:520px;overflow-y:auto">
            <table class="table table-sm table-hover font-monospace mb-0" style="font-size:.78rem">
                <tbody>
                    <?php foreach (array_reverse($entries) as $entry): ?>
                        <tr>
                            <td class="text-body-secondary text-nowrap pe-3" style="width:5rem">
                                <?= $this->e($entry['time']) ?>
                            </td>
                            <td class="text-nowrap pe-3" style="width:5rem">
                                <?= $levelBadge($entry['level']) ?>
                            </td>
                            <td class="text-body-secondary text-nowrap pe-3" style="width:10rem;overflow:hidden;text-overflow:ellipsis;max-width:10rem">
                                <?= $this->e($entry['logger']) ?>
                            </td>
                            <td style="word-break:break-all">
                                <?= $this->e($entry['msg']) ?>
                            </td>
                        </tr>
                    <?php endforeach ?>
                </tbody>
            </table>
        </div>
    <?php endif ?>
</div>
