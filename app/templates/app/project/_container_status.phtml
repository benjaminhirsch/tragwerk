<?php
/**
 * @var \Tragwerk\Domain\Entity\Project  $project
 * @var string                           $branch
 * @var list<array<string, mixed>>       $containers
 * @var string|null                      $error
 */
$statusUrl = $this->url('project.environment.container-status', ['id' => $project->id->toString()])
    . '?branch=' . urlencode($branch);
?>
<div hx-get="<?= $this->e($statusUrl) ?>"
     hx-trigger="every 30s"
     hx-target="#tw-container-status"
     hx-swap="innerHTML">
    <?php if ($error !== null): ?>
        <div class="d-flex align-items-center gap-2 text-body-secondary small">
            <i class="bi bi-exclamation-triangle text-warning flex-shrink-0"></i>
            <span><?= $this->e($error) ?></span>
        </div>
    <?php elseif ($containers === []): ?>
        <div class="text-body-secondary small">
            <i class="bi bi-info-circle me-1"></i>
            <?= $this->t('No containers running.') ?>
        </div>
    <?php else: ?>
        <ul class="list-group list-group-flush border rounded">
            <?php foreach ($containers as $container): ?>
                <?php
                $state   = (string) ($container['State'] ?? '');
                $health  = (string) ($container['Health'] ?? '');
                $status  = (string) ($container['Status'] ?? '');
                $service = (string) ($container['Service'] ?? '');
                $name    = (string) ($container['Name'] ?? '');

                if ($state === 'running' && $health === 'healthy') {
                    $icon       = 'bi-check-circle-fill text-success';
                    $badgeCss   = 'bg-success-subtle text-success border border-success-subtle';
                    $badgeLabel = $this->t('Healthy');
                } elseif ($state === 'running' && $health === 'unhealthy') {
                    $icon       = 'bi-exclamation-circle-fill text-danger';
                    $badgeCss   = 'bg-danger-subtle text-danger border border-danger-subtle';
                    $badgeLabel = $this->t('Unhealthy');
                } elseif ($state === 'running' && $health === 'starting') {
                    $icon       = 'bi-arrow-clockwise text-warning';
                    $badgeCss   = 'bg-warning-subtle text-warning border border-warning-subtle';
                    $badgeLabel = $this->t('Starting');
                } elseif ($state === 'running') {
                    $icon       = 'bi-play-circle-fill text-primary';
                    $badgeCss   = 'bg-primary-subtle text-primary border border-primary-subtle';
                    $badgeLabel = $this->t('Running');
                } elseif ($state === 'restarting') {
                    $icon       = 'bi-arrow-repeat text-warning';
                    $badgeCss   = 'bg-warning-subtle text-warning border border-warning-subtle';
                    $badgeLabel = $this->t('Restarting');
                } else {
                    $icon       = 'bi-stop-circle-fill text-secondary';
                    $badgeCss   = 'bg-secondary-subtle text-secondary border border-secondary-subtle';
                    $badgeLabel = $this->t('Stopped');
                }
                ?>
                <li class="list-group-item d-flex align-items-center gap-3 py-2">
                    <i class="bi <?= $icon ?> flex-shrink-0"></i>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="fw-medium small"><?= $this->e($service) ?></div>
                        <div class="text-body-secondary text-truncate" style="font-size:.75rem">
                            <?= $this->e($name) ?>
                        </div>
                    </div>
                    <div class="flex-shrink-0 text-end">
                        <span class="badge <?= $badgeCss ?>"><?= $badgeLabel ?></span>
                        <?php if ($status !== ''): ?>
                            <div class="text-body-secondary text-truncate mt-1" style="font-size:.7rem;max-width:14rem">
                                <?= $this->e($status) ?>
                            </div>
                        <?php endif ?>
                    </div>
                </li>
            <?php endforeach ?>
        </ul>
    <?php endif ?>
</div>
