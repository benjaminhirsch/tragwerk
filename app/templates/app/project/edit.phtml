<?php
/**
 * @var \Tragwerk\Domain\Entity\Project        $project
 * @var list<\Tragwerk\Domain\Entity\Server>   $servers
 * @var list<\Tragwerk\Domain\Entity\Server>   $allServers
 * @var list<\Tragwerk\Domain\Entity\Registry> $registries
 * @var list<\Tragwerk\Domain\Entity\SwarmNode> $existingNodes
 */
$this->layout('layout::default', ['title' => $this->t('Edit project')]);

$existingNodeMap = [];
foreach ($existingNodes as $node) {
    $existingNodeMap[$node->serverId->toString()] = $node;
}
?>

<h1><?= $this->t('Edit project') ?></h1>

<style>
    #tw-swarm-section { display: none; }
    form:has(#swarmEnabled:checked) #tw-swarm-section { display: block; }
</style>

<?php $this->start('card-content') ?>
    <form action="<?= $this->url('project.edit', ['id' => $project->id->toString()]) ?>" method="post">
        <?= $this->fetch('partial::input/csrf') ?>

        <?= $this->fetch('partial::input/text', [
            'id'         => 'name',
            'label'      => $this->t('Project name'),
            'autofocus'  => 'autofocus',
            'validation' => $validationBag,
        ]) ?>

        <?php
            $serverOptions = [];
            foreach ($servers as $server) {
                $serverOptions[$server->id->toString()] = $server->name;
            }
        ?>
        <?= $this->fetch('partial::input/select', [
            'id'           => 'serverId',
            'label'        => $this->t('Primary server (Swarm Manager)'),
            'validation'   => $validationBag,
            'options'      => $serverOptions,
            'defaultValue' => $validationBag->getValueByName('serverId'),
        ]) ?>

        <?php
            $registryOptions = ['' => $this->t('— None (build on server) —')];
            foreach ($registries as $registry) {
                $registryOptions[$registry->id->toString()] = $registry->name . ' (' . $registry->url . ')';
            }
        ?>
        <?= $this->fetch('partial::input/select', [
            'id'           => 'registryId',
            'label'        => $this->t('Container registry'),
            'validation'   => $validationBag,
            'options'      => $registryOptions,
            'defaultValue' => $validationBag->getValueByName('registryId'),
        ]) ?>

        <div class="mb-3 form-check">
            <input type="checkbox" class="form-check-input" id="swarmEnabled" name="swarmEnabled" value="1"
                   <?php if ($validationBag->getValueByName('swarmEnabled') === '1'): ?>checked<?php endif; ?>>
            <label class="form-check-label" for="swarmEnabled"><?= $this->t('Enable Docker Swarm') ?></label>
        </div>

        <div id="tw-swarm-section">
            <?php if (($validationBag->getErrorByName('swarmNodes') ?? null) !== null): ?>
                <div class="alert alert-danger"><?= $this->e($validationBag->getErrorByName('swarmNodes')) ?></div>
            <?php endif; ?>
            <?php if (($validationBag->getErrorByName('swarmStorageNodeId') ?? null) !== null): ?>
                <div class="alert alert-danger"><?= $this->e($validationBag->getErrorByName('swarmStorageNodeId')) ?></div>
            <?php endif; ?>

            <p class="text-muted small"><?= $this->t('Select at least 2 additional servers. Total manager count must be odd (1, 3, 5, …).') ?></p>

            <?php if (count($allServers) > 1): ?>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th><?= $this->t('Include') ?></th>
                            <th><?= $this->t('Server') ?></th>
                            <th><?= $this->t('Role') ?></th>
                            <th><?= $this->t('Storage node') ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($allServers as $server): ?>
                            <?php
                                $sid          = $server->id->toString();
                                $existingNode = $existingNodeMap[$sid] ?? null;
                                $isChecked    = $existingNode !== null;
                                $currentRole  = $existingNode?->role->value ?? 'worker';
                                $isStorage    = $existingNode?->isStorage ?? false;
                            ?>
                            <tr>
                                <td>
                                    <input type="checkbox" class="form-check-input"
                                           name="swarmNodes[<?= $this->e($sid) ?>]"
                                           value="1"
                                           <?php if ($isChecked): ?>checked<?php endif; ?>>
                                </td>
                                <td><?= $this->e($server->name) ?></td>
                                <td>
                                    <select class="form-select form-select-sm"
                                            name="swarmNodeRoles[<?= $this->e($sid) ?>]">
                                        <option value="worker" <?php if ($currentRole === 'worker'): ?>selected<?php endif; ?>><?= $this->t('Worker') ?></option>
                                        <option value="manager" <?php if ($currentRole === 'manager'): ?>selected<?php endif; ?>><?= $this->t('Manager') ?></option>
                                    </select>
                                </td>
                                <td>
                                    <input type="radio" class="form-check-input"
                                           name="swarmStorageNodeId"
                                           value="<?= $this->e($sid) ?>"
                                           <?php if ($isStorage): ?>checked<?php endif; ?>>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            <?php else: ?>
                <p class="text-warning"><?= $this->t('No additional servers available. Add more servers to your team to enable Swarm mode.') ?></p>
            <?php endif; ?>
        </div>

        <div class="d-flex gap-2">
            <?= $this->fetch('partial::input/button', [
                'label' => $this->t('Save'),
            ]) ?>

            <?= $this->fetch('partial::link', [
                'label'   => $this->t('Cancel'),
                'href'    => $this->url('project.show', ['id' => $project->id->toString()]),
                'classes' => 'btn btn-secondary',
            ]) ?>

            <?= $this->fetch('partial::input/button', [
                'classes'      => 'btn btn-outline-danger',
                'icon'         => 'bi bi-trash3',
                'type'         => 'button',
                'dataBsToggle' => 'modal',
                'dataBsTarget' => '#tw-delete-project-modal',
            ]) ?>
        </div>

    </form>
<?php $this->stop() ?>

<?= $this->fetch('partial::modal', [
    'id'            => 'tw-delete-project-modal',
    'header'        => $this->t('Delete project'),
    'body'          => $this->t('Are you sure you want to delete the project {name}? This action cannot be undone.', ['name' => '<strong>' . $this->e($project->name) . '</strong>']),
    'actionUrl'     => $this->url('project.delete', ['id' => $project->id->toString()]),
    'actionLabel'   => $this->t('Delete project'),
    'actionClasses' => 'btn btn-danger',
    'actionIcon'    => 'bi bi-trash3',
]) ?>
