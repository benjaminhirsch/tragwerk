<?php

/**
 * @var list<\Tragwerk\Domain\Entity\Server>                        $servers
 * @var array<string, int>                                          $serverProjectCounts
 * @var list<\Tragwerk\Domain\Entity\Registry>                      $registries
 * @var \Tragwerk\Application\Validation\ValidationBag|null         $validationBag
 */

$this->layout('layout::default', [
    'pageType' =>  $this->activeTeam()->name,
    'pageTitle' => $this->t('Create project'),
    'pageSubTitle' => $this->t('A new project contains its own environments, servers and registries'),
    'wide' => false,
]) ?>


<form class="tw-card" action="<?= $this->url('project.create') ?>" method="post">
    <div class="tw-card__body d-flex flex-column gap-3">
    <?= $this->fetch('partial::input/csrf') ?>

    <?= $this->fetch('partial::input/text', [
        'id'         => 'name',
        'label'      => $this->t('Project name'),
        'autofocus'  => 'autofocus',
        'validation' => $validationBag ?? null,
    ]) ?>

    <?php
        $serverOptions = [];
        foreach ($servers as $server) {
            $count = $serverProjectCounts[$server->id->toString()] ?? 0;
            $serverOptions[$server->id->toString()] = $count > 0
                ? $server->name . ' (' . $count . ' ' . ($count === 1 ? $this->t('project') : $this->t('projects')) . ')'
                : $server->name;
        }
    ?>
    <?= $this->fetch('partial::input/select', [
        'id'                 => 'serverId',
        'label'              => $this->t('Server'),
        'validation'         => $validationBag ?? null,
        'options'            => $serverOptions,
        'defaultOptionLabel' => $this->t('— select a server —'),
    ]) ?>

    <?php
        $registryOptions = [];
        foreach ($registries as $registry) {
            $registryOptions[$registry->id->toString()] = $registry->name . ' (' . $registry->url . ')';
        }
    ?>
    <?= $this->fetch('partial::input/select', [
        'id'                 => 'registryId',
        'label'              => $this->t('Container registry'),
        'validation'         => $validationBag ?? null,
        'options'            => $registryOptions,
        'defaultOptionLabel' => $this->t('— select a registry —'),
        'defaultValue'       => ($validationBag?->getValueByName('registryId') ?? ''),
    ]) ?>
    </div>
    <div class="tw-card__head  justify-content-end border-top">
        <?= $this->fetch('partial::link', [
                'label'   => $this->t('Cancel'),
                'href'    => $this->url('project'),
                'classes' => 'btn btn-ghost',
        ]) ?>
        <?= $this->fetch('partial::input/button', [
            'label' => $this->t('Create project'),
            'icon' => 'bi bi-check-lg',
        ]) ?>
    </div>
</form>
