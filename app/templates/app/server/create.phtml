<?php $this->layout('layout::default', ['title' => _('Create server')]) ?>

<h1><?= _('Create server') ?></h1>

<?php $this->start('card-content') ?>
    <form action="<?= $this->url('server.create') ?>" method="post">
        <?= $this->fetch('partial::input/csrf') ?>
        <?= $this->fetch('partial::input/text', [
                'id' => 'name',
                'label' => _('Server name'),
                'autofocus' => 'autofocus',
                'validation' => $validationBag ?? null
        ]) ?>
        <?= $this->fetch('partial::input/text', [
                'id' => 'host',
                'label' => _('IP address (IPv4 or IPv6)'),
                'validation' => $validationBag ?? null
        ]) ?>
        <?= $this->fetch('partial::input/input', [
                'id'         => 'port',
                'type'       => 'number',
                'label'      => _('SSH port'),
                'min'        => '1',
                'max'        => '65535',
                'validation' => $validationBag ?? null,
        ]) ?>
        <?php
            $credentialOptions = [];
            foreach ($credentials as $cred) {
                $credentialOptions[$cred->id->toString()] = $cred->name;
            }
        ?>
        <?= $this->fetch('partial::input/select', [
            'id'                 => 'credentialId',
            'label'              => _('Credential'),
            'validation'         => $validationBag ?? null,
            'options'            => $credentialOptions,
            'defaultOptionLabel' => _('— no credential —'),
        ]) ?>
        <?= $this->fetch('partial::input/button', [
                'label' => _('Save'),
        ]) ?>
        <?= $this->fetch('partial::link', [
                'label' => _('Cancel'),
                'href' => $this->url('server'),
                'classes' => 'btn btn-secondary',
        ]) ?>
    </form>
<?php $this->stop() ?>