<?php
/** @var \Tragwerk\Domain\Entity\Server $server */
/** @var \Tragwerk\Domain\Entity\Credential|null $credential */
?>
<table class="table table-borderless mb-0">
    <tbody>
        <tr>
            <th class="w-25 text-body-secondary fw-normal"><?= $this->t('Host') ?></th>
            <td><code><?= $this->e($server->host) ?></code></td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= $this->t('SSH Port') ?></th>
            <td><code><?= $this->e((string) $server->port) ?></code></td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= $this->t('Credential') ?></th>
            <td>
                <?php if ($credential !== null): ?>
                    <?= $this->fetch('partial::link', [
                        'href'  => $this->url('credential.show', ['id' => $credential->id->toString()]),
                        'label' => $credential->name,
                    ]) ?>
                <?php else: ?>
                    <span class="text-body-secondary">—</span>
                <?php endif ?>
            </td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= $this->t('Docker') ?></th>
            <td>
                <?php if ($server->dockerVersion !== null): ?>
                    <code><?= $this->e($server->dockerVersion) ?></code>
                <?php else: ?>
                    <span class="text-body-secondary">—</span>
                <?php endif ?>
            </td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= $this->t('Docker Compose') ?></th>
            <td>
                <?php if ($server->dockerComposeVersion !== null): ?>
                    <code><?= $this->e($server->dockerComposeVersion) ?></code>
                <?php else: ?>
                    <span class="text-body-secondary">—</span>
                <?php endif ?>
            </td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= $this->t('Created') ?></th>
            <td><?= $this->e($server->createdAt->format('Y-m-d H:i')) ?></td>
        </tr>
    </tbody>
</table>
