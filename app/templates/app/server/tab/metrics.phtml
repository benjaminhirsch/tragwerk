<?php

declare(strict_types=1);

/** @var \Tragwerk\Domain\Entity\Server $server */

$liveUrl = $this->url('server.metrics.live', ['id' => $server->id->toString()]);
$dataUrl = $this->url('server.metrics.data', ['id' => $server->id->toString()]);
?>
<div class="row g-4">
    <div class="col-12">
        <h6 class="text-body-secondary mb-2"><?= $this->t('Live') ?></h6>
        <div id="tw-metrics-live"
             hx-get="<?= $this->e($liveUrl) ?>"
             hx-trigger="load"
             hx-swap="innerHTML">
            <div class="text-body-secondary small">
                <span class="spinner-border spinner-border-sm me-1"></span><?= $this->t('Loading…') ?>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div id="tw-metrics-charts" data-url="<?= $this->e($dataUrl) ?>" data-range="1h">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="text-body-secondary mb-0"><?= $this->t('History') ?></h6>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-secondary active" data-range="1h">1h</button>
                    <button type="button" class="btn btn-outline-secondary" data-range="6h">6h</button>
                    <button type="button" class="btn btn-outline-secondary" data-range="24h">24h</button>
                </div>
            </div>

            <div class="small text-body-secondary mb-1"><?= $this->t('Utilization (%)') ?></div>
            <div data-chart="usage" class="mb-3"></div>

            <div class="small text-body-secondary mb-1"><?= $this->t('Load (1m)') ?></div>
            <div data-chart="load"></div>

            <div data-chart-empty class="text-body-secondary small d-none">
                <i class="bi bi-info-circle me-1"></i><?= $this->t('No data yet — samples appear as the metrics ticker runs.') ?>
            </div>
        </div>
    </div>
</div>
