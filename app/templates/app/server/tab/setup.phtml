<?php
/** @var \Tragwerk\Domain\Entity\Server $server */
/** @var \Tragwerk\Domain\Entity\SetupJob|null $latestJob */
/** @var bool $jobActive */
?>
<?php if ($latestJob === null): ?>
    <p class="text-body-secondary mb-3"><?= _('No setup has been run yet.') ?></p>
<?php else: ?>
    <?= $this->fetch('page::server/_log_widget', ['server' => $server, 'job' => $latestJob]) ?>
<?php endif ?>

<?php if (! $jobActive): ?>
<div class="mt-3">
    <form action="<?= $this->url('server.setup.start', ['id' => $server->id->toString()]) ?>" method="post">
        <?= $this->fetch('partial::input/csrf') ?>
        <?= $this->fetch('partial::input/button', [
            'label'   => $latestJob !== null ? _('Run setup again') : _('Run setup'),
            'icon'    => 'bi bi-play-circle',
            'classes' => 'btn btn-outline-primary',
        ]) ?>
    </form>
</div>
<?php endif ?>
