                <i class="bi bi-trash3"></i>
            </button>
        <?php endif ?>
    </div>
</div>

<?php if ($deleteBlocked): ?>
    <div class="tw-card mb-4" style="border-color:var(--danger-soft)">
        <div class="tw-card__body d-flex align-items-center gap-2" style="color:var(--danger-text)">
