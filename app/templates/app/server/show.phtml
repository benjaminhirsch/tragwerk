<?php

declare(strict_types=1);

use Tragwerk\Domain\Enum\SetupJobStatus;

/**
 * @var \Tragwerk\Domain\Entity\Server          $server
 * @var \Tragwerk\Domain\Entity\Credential|null $credential
 * @var \Tragwerk\Domain\Entity\SetupJob|null   $latestJob
 * @var bool                                    $jobActive
 * @var list<\Tragwerk\Domain\Entity\Project>   $workloads
