    SetupJobStatus::Failed    => '<span class="tw-badge tw-badge--danger"><span class="tw-dot"></span>' . $this->e($this->t('Setup failed')) . '</span>',
    SetupJobStatus::Running, SetupJobStatus::Pending => '<span class="tw-badge tw-badge--info tw-badge--building"><span class="tw-dot"></span>' . $this->e($this->t('Provisioning')) . '</span>',
    default => '<span class="tw-badge"><span class="tw-dot"></span>' . $this->e($this->t('Not set up')) . '</span>',
};

$dataUrl = $this->url('server.metrics.data', ['id' => $server->id->toString()]);
