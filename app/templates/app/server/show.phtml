                    <?= $this->fetch('partial::link', ['href' => $this->url('credential.edit', ['id' => $credential->id->toString()]), 'label' => $credential->name]) ?>
                <?php else: ?><span class="text-body-secondary">—</span><?php endif ?>
            </span></div>
            <div class="cfg-row"><span class="k"><?= $this->t('Docker') ?></span><span class="v mono" style="font-size:.8rem"><?= $server->dockerVersion !== null ? $this->e($server->dockerVersion) : '—' ?></span></div>
            <div class="cfg-row"><span class="k"><?= $this->t('Docker Compose') ?></span><span class="v mono" style="font-size:.8rem"><?= $server->dockerComposeVersion !== null ? $this->e($server->dockerComposeVersion) : '—' ?></span></div>
            <div class="cfg-row"><span class="k"><?= $this->t('Created') ?></span><span class="v"><?= $this->e($server->createdAt->format('Y-m-d')) ?></span></div>
        </div></div>

        <h2 style="font-size:1.1rem;margin:0 0 .5rem"><?= $this->t('Hosted workloads') ?></h2>
        <div class="tw-card"><div class="tw-card__body">
            <?php if ($workloads === []): ?>
                <span class="text-body-secondary small"><?= $this->t('No projects deployed to this server yet.') ?></span>
            <?php else: ?>
                <div class="d-flex flex-column gap-2">
                    <?php foreach ($workloads as $project): ?>
                        <a class="d-flex align-items-center gap-2" href="<?= $this->url('project.show', ['id' => $project->id->toString()]) ?>" style="color:var(--text);font-weight:600;font-size:.9rem">
