?>

<a class="d-inline-flex align-items-center gap-2 mb-3" href="<?= $this->url('server') ?>" style="color:var(--text-muted);font-weight:600;font-size:.86rem">
    <i class="bi bi-arrow-left"></i> <?= $this->e($this->t('Servers')) ?>
</a>

<div class="tw-pagehead">
    <div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
