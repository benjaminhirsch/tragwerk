            </div></div>
        <?php else: ?>
            <?= $this->fetch('page::server/_log_widget', ['server' => $server, 'job' => $latestJob]) ?>
        <?php endif ?>

        <?php if (! $jobActive): ?>
            <form class="mt-3" action="<?= $this->url('server.setup.start', ['id' => $server->id->toString()]) ?>" method="post">
                <?= $this->fetch('partial::input/csrf') ?>
                <?= $this->fetch('partial::input/button', [
                    'label'   => $latestJob !== null ? $this->t('Run setup again') : $this->t('Run setup'),
                    'icon'    => 'bi bi-play-circle',
                    'classes' => 'btn btn-outline-primary',
                ]) ?>
            </form>
        <?php endif ?>
    </div>

    <!-- Right: details + workloads -->
    <div class="col-lg-4">
        <h2 style="font-size:1.1rem;margin:0 0 .5rem"><?= $this->t('Details') ?></h2>
        <div class="tw-card mb-4"><div class="tw-card__body">
