                        </div>
                        <div class="tw-chart-card__body"><div class="tw-chart-box" id="<?= $id ?>" style="height:150px"></div></div>
                    </div>
                </div>
                <?php endforeach ?>
            </div>
        </div>

        <!-- Setup log -->
        <div class="d-flex align-items-center justify-content-between mb-2">
            <div>
                <h2 style="font-size:1.1rem;margin:0"><?= $this->t('Setup log') ?></h2>
                <p class="text-faint m-0" style="font-size:.82rem"><?= $this->t('Provisioning & bootstrap output.') ?></p>
            </div>
        </div>

        <?php if ($latestJob === null): ?>
            <div class="tw-card mb-3"><div class="tw-card__body text-body-secondary small">
