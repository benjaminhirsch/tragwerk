                <td>
                    <?php if ($server->credentialId !== null): ?>
                        <i class="bi bi-check-circle-fill text-success"></i>
                    <?php else: ?>
                        <i class="bi bi-x-circle text-secondary"></i>
                    <?php endif ?>
                </td>
                <td class="tw-hide-sm"><?= $server->dockerVersion !== null ? $this->e($server->dockerVersion) : '<span class="text-secondary">—</span>' ?></td>
                <td class="tw-hide-sm"><?= $server->dockerComposeVersion !== null ? $this->e($server->dockerComposeVersion) : '<span class="text-secondary">—</span>' ?></td>
                <td>
                    <?php if (in_array($server->id->toString(), $completedIds, true)): ?>
                        <i class="bi bi-check-circle-fill text-success"></i>
