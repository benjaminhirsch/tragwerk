<?php $this->layout('layout::default', ['title' => _('Servers')]) ?>

<h1><?= _('Servers') ?></h1>

<div class="tw-card">
    <?= $this->fetch('partial::link', [
        'label'   => _('Create server'),
        'icon'    => 'bi bi-plus-circle',
        'classes' => 'btn btn-primary',
        'href'    => $this->url('server.create'),
    ]) ?>

    <hr />

    <table class="table table-striped table-hover">
        <thead>
        <tr>
            <th><?= _('Name') ?></th>
            <th><?= _('IP address') ?></th>
            <th><?= _('Credentials assigned') ?></th>
            <th><?= _('Ready to deploy') ?></th>
        </tr>
        </thead>
        <tbody>
        <?php
        /** @var \Tragwerk\Domain\Entity\Server $server */
        /** @var string[] $completedIds */
        foreach ($servers as $server): ?>
            <tr>
                <td><?= $this->fetch('partial::link', [
                        'href'  => $this->url('server.edit', ['id' => $server->id]),
                        'label' => $server->name,
                    ]) ?></td>
                <td><?= $this->e($server->host) ?></td>
                <td>
                    <?php if ($server->credentialId !== null): ?>
                        <i class="bi bi-check-circle-fill text-success"></i>
                    <?php else: ?>
                        <i class="bi bi-x-circle text-secondary"></i>
                    <?php endif ?>
                </td>
                <td>
                    <?php if (in_array($server->id->toString(), $completedIds, true)): ?>
                        <i class="bi bi-check-circle-fill text-success"></i>
                    <?php else: ?>
                        <i class="bi bi-x-circle text-secondary"></i>
                    <?php endif ?>
                </td>
            </tr>
        <?php endforeach ?>
        </tbody>
    </table>
</div>
