<?php
/** @var \Tragwerk\Domain\Entity\Server $server */
/** @var \Tragwerk\Domain\Entity\SetupJob $job */
$polling  = $job->status->value === 'pending' || $job->status->value === 'running';
$logUrl   = $this->url('server.setup.log', ['id' => $server->id->toString(), 'jobId' => $job->id->toString()]);
$topicBase = $_SERVER['MERCURE_TOPIC_BASE'] ?? 'https://tragwerk.build';
$sseTopic  = urlencode($topicBase . '/server/' . $server->id->toString() . '/setup-job/' . $job->id->toString());
?>
<div id="tw-setup-log"
    <?php if ($polling): ?>
    hx-ext="sse"
    sse-connect="/.well-known/mercure?topic=<?= $sseTopic ?>"
    hx-get="<?= $this->e($logUrl) ?>"
    hx-trigger="sse:message, every 30s"
    hx-swap="outerHTML"
    <?php endif ?>
>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <?php if ($job->status->value === 'completed'): ?>
            <span class="badge bg-success"><?= $this->t('Completed') ?></span>
        <?php elseif ($job->status->value === 'failed'): ?>
            <span class="badge bg-danger"><?= $this->t('Failed') ?></span>
        <?php elseif ($job->status->value === 'running'): ?>
            <span class="badge bg-primary">
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                <?= $this->t('Running') ?>
            </span>
        <?php else: ?>
            <span class="badge bg-secondary"><?= $this->t('Pending') ?></span>
        <?php endif ?>
    </div>

    <pre class="bg-dark text-light p-3 rounded"
         style="min-height: 200px; max-height: 600px; overflow-y: auto; font-size: 0.85rem; white-space: pre-wrap;"
    ><?= $this->e($job->output) ?></pre>
</div>
