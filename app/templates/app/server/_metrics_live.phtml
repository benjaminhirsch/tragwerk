<?php

declare(strict_types=1);

/**
 * @var \Tragwerk\Domain\Entity\Server                 $server
 * @var \Tragwerk\Domain\Model\ServerMetricSample|null $sample
 * @var list<array<string, mixed>>                     $containers
 * @var string|null                                    $error
 */

$liveUrl = $this->url('server.metrics.live', ['id' => $server->id->toString()]);

$fmtBytes = static function (int $bytes): string {
    $units = ['B', 'KiB', 'MiB', 'GiB', 'TiB'];
    $value = (float) $bytes;
    $i     = 0;
    while ($value >= 1024 && $i < 4) {
        $value /= 1024;
        $i++;
    }

    return sprintf('%.1f %s', $value, $units[$i]);
};

$barClass = static function (float $pct): string {
    if ($pct >= 90.0) {
        return 'bg-danger';
    }

    if ($pct >= 75.0) {
        return 'bg-warning';
    }

    return 'bg-success';
};

$gauge = function (string $label, float $pct, string $detail) use ($barClass): string {
    $pct = max(0.0, min(100.0, $pct));

    return '<div class="mb-3">'
        . '<div class="d-flex justify-content-between small mb-1">'
        . '<span class="fw-medium">' . $this->e($label) . '</span>'
        . '<span class="text-body-secondary">' . $this->e($detail) . '</span>'
        . '</div>'
        . '<div class="progress" role="progressbar" style="height:.5rem">'
        . '<div class="progress-bar ' . $barClass($pct) . '" style="width:' . round($pct, 1) . '%"></div>'
        . '</div></div>';
};
?>
<div hx-get="<?= $this->e($liveUrl) ?>"
     hx-trigger="every 15s"
     hx-target="#tw-metrics-live"
     hx-swap="innerHTML">
    <?php if ($error !== null): ?>
        <div class="d-flex align-items-center gap-2 text-body-secondary small">
            <i class="bi bi-exclamation-triangle text-warning flex-shrink-0"></i>
            <span><?= $this->e($error) ?></span>
        </div>
    <?php elseif ($sample === null): ?>
        <div class="text-body-secondary small">
            <i class="bi bi-info-circle me-1"></i>
            <?= $this->t('No metrics available.') ?>
        </div>
    <?php else: ?>
        <?php
        $memPct  = $sample->memTotalBytes > 0 ? ($sample->memUsedBytes / $sample->memTotalBytes) * 100 : 0.0;
        $diskPct = $sample->diskTotalBytes > 0 ? ($sample->diskUsedBytes / $sample->diskTotalBytes) * 100 : 0.0;
        ?>
        <div class="row g-3">
            <div class="col-md-6">
                <?= $gauge($this->t('CPU'), $sample->cpuPercent, sprintf('%.1f %%', $sample->cpuPercent)) ?>
                <?= $gauge(
                    $this->t('Memory'),
                    $memPct,
                    $fmtBytes($sample->memUsedBytes) . ' / ' . $fmtBytes($sample->memTotalBytes),
                ) ?>
            </div>
            <div class="col-md-6">
                <?= $gauge(
                    $this->t('Disk'),
                    $diskPct,
                    $fmtBytes($sample->diskUsedBytes) . ' / ' . $fmtBytes($sample->diskTotalBytes),
                ) ?>
                <div class="mb-3">
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="fw-medium"><?= $this->t('Load (1m)') ?></span>
                        <span class="text-body-secondary"><?= $this->e(sprintf('%.2f', $sample->load1)) ?></span>
                    </div>
                </div>
            </div>
        </div>

        <?php if ($containers !== []): ?>
            <h6 class="mt-3 mb-2 text-body-secondary"><?= $this->t('Containers') ?></h6>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr class="small text-body-secondary">
                            <th><?= $this->t('Name') ?></th>
                            <th class="text-end"><?= $this->t('CPU') ?></th>
                            <th class="text-end"><?= $this->t('Memory') ?></th>
                            <th class="text-end"><?= $this->t('Mem %') ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($containers as $c): ?>
                            <tr class="small">
                                <td class="text-truncate" style="max-width:16rem">
                                    <?= $this->e((string) ($c['Name'] ?? '')) ?>
                                </td>
                                <td class="text-end"><?= $this->e((string) ($c['CPUPerc'] ?? '')) ?></td>
                                <td class="text-end"><?= $this->e((string) ($c['MemUsage'] ?? '')) ?></td>
                                <td class="text-end"><?= $this->e((string) ($c['MemPerc'] ?? '')) ?></td>
                            </tr>
                        <?php endforeach ?>
                    </tbody>
                </table>
            </div>
        <?php endif ?>
    <?php endif ?>
</div>
