    'pageSubTitle' => $this->t('Generate a fresh set of one-time recovery codes.'),
    'wide'         => false,
]);
?>

<div class="acct">
    <div class="tw-card">
        <div class="tw-card__head">
            <h2><?= $this->t('Recovery codes') ?></h2>
            <?= $this->fetch('partial::badge', [
                'type'  => $remaining > 0 ? 'ok' : 'warning',
                'label' => $this->t('{count} remaining', ['count' => (string) $remaining]),
            ]) ?>
        </div>
        <div class="tw-card__body">

