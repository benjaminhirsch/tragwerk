<?php

declare(strict_types=1);

/** @var \Tragwerk\Application\Validation\ValidationBag|null $validationBag */

$this->layout('layout::default', [
    'pageType'     => $this->activeTeam()->name,
    'pageTitle'    => $this->t('Create credential'),
    'pageSubTitle' => $this->t('Store an SSH key so servers can be connected to.'),
    'wide'         => false,
]);
?>

<form class="tw-card" action="<?= $this->url('credential.create') ?>" method="post">
    <div class="tw-card__body d-flex flex-column gap-3">
        <?= $this->fetch('partial::input/csrf') ?>

        <?= $this->fetch('partial::input/text', [
            'id'         => 'name',
            'label'      => $this->t('Name'),
            'autofocus'  => 'autofocus',
            'validation' => $validationBag ?? null,
        ]) ?>

        <?= $this->fetch('partial::input/text', [
            'id'         => 'username',
            'label'      => $this->t('Username'),
            'validation' => $validationBag ?? null,
        ]) ?>

        <div>
            <?= $this->fetch('partial::input/enum', [
                'id'                 => 'privilege',
                'label'              => $this->t('Privilege level'),
                'options'            => \Tragwerk\Domain\Enum\CredentialPrivilege::cases(),
                'defaultValue'       => \Tragwerk\Domain\Enum\CredentialPrivilege::Root,
                'disableEmptyOption' => true,
                'validation'         => $validationBag ?? null,
            ]) ?>
            <small class="text-muted"><?= $this->e($this->t('Sudo requires passwordless sudo (NOPASSWD) for the user.')) ?></small>
        </div>

        <?= $this->fetch('partial::input/textarea', [
            'id'         => 'privateKey',
            'label'      => $this->t('Private key'),
            'validation' => $validationBag ?? null,
        ]) ?>
    </div>
    <div class="tw-card__head justify-content-end border-top">
        <?= $this->fetch('partial::link', [
            'label'   => $this->t('Cancel'),
            'href'    => $this->url('credential'),
            'classes' => 'btn btn-ghost',
        ]) ?>
        <?= $this->fetch('partial::input/button', [
            'label' => $this->t('Save'),
            'icon'  => 'bi bi-check-lg',
        ]) ?>
    </div>
</form>
