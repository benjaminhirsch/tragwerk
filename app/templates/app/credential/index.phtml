<?php $this->layout('layout::default', ['title' => _('Credentials')]) ?>

<h1><?= _('Credentials') ?></h1>

<div class="tw-card">
    <?= $this->fetch('partial::link', [
        'label'   => _('Create credential'),
        'icon'    => 'bi bi-plus-circle',
        'classes' => 'btn btn-primary',
        'href'    => $this->url('credential.create'),
    ]) ?>

    <hr />

    <table class="table table-striped table-hover">
        <thead>
        <tr>
            <th><?= _('Name') ?></th>
            <th><?= _('Username') ?></th>
            <th><?= _('SSH Key') ?></th>
        </tr>
        </thead>
        <tbody>
        <?php foreach ($credentials as $credential): ?>
            <tr>
                <td><?= $this->fetch('partial::link', [
                        'href'  => $this->url('credential.edit', ['id' => $credential->id]),
                        'label' => $credential->name,
                    ]) ?></td>
                <td><?= $this->e($credential->username) ?></td>
                <td>
                    <?php if ($credential->privateKey !== null): ?>
                        <i class="bi bi-check-circle-fill text-success"></i>
                    <?php else: ?>
                        <i class="bi bi-x-circle text-secondary"></i>
                    <?php endif ?>
                </td>
            </tr>
        <?php endforeach ?>
        </tbody>
    </table>
</div>
