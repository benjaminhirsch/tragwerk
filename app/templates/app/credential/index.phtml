<?php

$this->layout('layout::default', [
        'pageType' =>  $this->activeTeam()->name,
        'pageTitle' => $this->t('Credentials'),
        'pageSubTitle' => $this->t('SSH credentials used to connect to servers — shared across the team.'),
]) ?>

<?php $this->start('pageHeadButtons') ?>
<?= $this->fetch('partial::link', [
        'label'   => $this->t('Create credential'),
        'icon'    => 'bi bi-plus-circle',
        'classes' => 'btn btn-primary',
        'href'    => $this->url('credential.create'),
]) ?>
<?php $this->stop() ?>

<div class="tw-table-wrap">
    <table class="tw-table">
        <thead>
        <tr>
            <th class="sortable"><?= $this->t('Name') ?></th>
            <th class="sortable tw-hide-sm"><?= $this->t('Username') ?></th>
            <th class="sortable"><?= $this->t('SSH Key') ?></th>
        </tr>
        </thead>
        <tbody>
        <?php
        /** @var \Tragwerk\Domain\Entity\Credential $credential */
        foreach ($credentials as $credential): ?>
            <tr>
                <td><span class="tw-cell-strong"><?= $this->fetch('partial::link', [
                        'href'  => $this->url('credential.edit', ['id' => $credential->id]),
                        'label' => $credential->name,
                        ]) ?></span></td>
                <td class="tw-hide-sm"><?= $this->e($credential->username) ?></td>
                <td>
                    <?php if ($credential->privateKey !== null): ?>
                        <i class="bi bi-check-circle-fill text-success"></i>
                    <?php else: ?>
                        <i class="bi bi-x-circle text-secondary"></i>
                    <?php endif ?>
                </td>
            </tr>
        <?php endforeach ?>
        <?php if ($credentials === []): ?>
            <tr>
                <td class="text-center" colspan="3">
                    <?= $this->t('No credentials configured yet. Add credentials first to use them in the team wo setup servers.') ?>
                </td>
            </tr>
        <?php endif; ?>
        </tbody>
    </table>
</div>
