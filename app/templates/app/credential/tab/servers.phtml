<?php
/** @var \Tragwerk\Domain\Entity\Server[] $servers */
?>
<?php if ($servers === []): ?>
    <p class="text-body-secondary mb-0"><?= _('No servers are using this credential.') ?></p>
<?php else: ?>
    <table class="table table-borderless mb-0">
        <thead>
            <tr>
                <th><?= _('Name') ?></th>
                <th><?= _('Host') ?></th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($servers as $server): ?>
                <tr>
                    <td>
                        <?= $this->fetch('partial::link', [
                            'href'  => $this->url('server.show', ['id' => $server->id->toString()]),
                            'label' => $server->name,
                        ]) ?>
                    </td>
                    <td><code><?= $this->e($server->host) ?></code></td>
                </tr>
            <?php endforeach ?>
        </tbody>
    </table>
<?php endif ?>
