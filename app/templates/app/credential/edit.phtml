<?php $this->layout('layout::default', ['title' => $this->t('Edit credential')]) ?>

<h1><?= $this->t('Edit credential') ?></h1>

<?php $this->start('card-content') ?>
    <form action="<?= $this->url('credential.edit', ['id' => $credential->id->toString()]) ?>" method="post">
        <?= $this->fetch('partial::input/csrf') ?>

        <?= $this->fetch('partial::input/text', [
            'id'         => 'name',
            'label'      => $this->t('Name'),
            'autofocus'  => 'autofocus',
            'validation' => $validationBag,
        ]) ?>

        <?= $this->fetch('partial::input/text', [
            'id'         => 'username',
            'label'      => $this->t('Username'),
            'validation' => $validationBag,
        ]) ?>

        <?= $this->fetch('partial::input/textarea', [
                'id'         => 'privateKey',
                'label'      => $this->t('Private key'),
                'validation' => $validationBag
        ]) ?>

        <?php if ($deleteBlocked ?? false): ?>
            <div class="alert alert-danger" role="alert">
                <?= $this->t('This credential is assigned to one or more servers and cannot be deleted. Remove the assignment first.') ?>
            </div>
        <?php elseif ($isAssigned ?? false): ?>
            <div class="alert alert-warning" role="alert">
                <?= $this->t('This credential is currently assigned to one or more servers. Remove the assignment before deleting.') ?>
            </div>
        <?php endif ?>

        <div class="d-flex gap-2">
            <?= $this->fetch('partial::input/button', [
                'label' => $this->t('Save'),
            ]) ?>
            <?= $this->fetch('partial::link', [
                'label'   => $this->t('Cancel'),
                'href'    => $this->url('credential'),
                'classes' => 'btn btn-secondary',
            ]) ?>
            <?php if (! ($isAssigned ?? false)): ?>
                <?= $this->fetch('partial::input/button', [
                    'classes'      => 'btn btn-outline-danger',
                    'icon'         => 'bi bi-trash3',
                    'type'         => 'button',
                    'dataBsToggle' => 'modal',
                    'dataBsTarget' => '#tw-delete-credential-modal',
                ]) ?>
            <?php endif ?>
        </div>
    </form>
<?php $this->stop() ?>

<?= $this->fetch('partial::modal', [
    'id'            => 'tw-delete-credential-modal',
    'header'        => $this->t('Delete credential'),
    'body'          => $this->t('Are you sure you want to delete the credential {name}? This action cannot be undone.', ['name' => '<strong>' . $this->e($credential->name) . '</strong>']),
    'actionUrl'     => $this->url('credential.delete', ['id' => $credential->id->toString()]),
    'actionLabel'   => $this->t('Delete credential'),
    'actionClasses' => 'btn btn-danger',
    'actionIcon'    => 'bi bi-trash3',
]) ?>
