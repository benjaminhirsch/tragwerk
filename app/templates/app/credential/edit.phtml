<?php

declare(strict_types=1);

/**
 * @var \Tragwerk\Domain\Entity\Credential            $credential
 * @var \Tragwerk\Application\Validation\ValidationBag $validationBag
 * @var list<\Tragwerk\Domain\Entity\Server>           $servers
 * @var bool                                           $isAssigned
 */

$this->layout('layout::default', [
    'pageType'     => $this->activeTeam()->name,
    'pageTitle'    => $this->t('Edit credential'),
    'pageSubTitle' => $this->t('Update name, username and SSH key for this credential.'),
    'wide'         => false,
]);
?>

<form class="tw-card" action="<?= $this->url('credential.edit', ['id' => $credential->id->toString()]) ?>" method="post">
    <div class="tw-card__body d-flex flex-column gap-3">
        <?= $this->fetch('partial::input/csrf') ?>

        <?= $this->fetch('partial::input/text', [
            'id'         => 'name',
            'label'      => $this->t('Name'),
            'autofocus'  => 'autofocus',
            'validation' => $validationBag,
        ]) ?>

        <?= $this->fetch('partial::input/text', [
            'id'         => 'username',
            'label'      => $this->t('Username'),
            'validation' => $validationBag,
        ]) ?>

        <?= $this->fetch('partial::input/textarea', [
            'id'         => 'privateKey',
            'label'      => $this->t('Private key'),
            'validation' => $validationBag,
        ]) ?>
    </div>
    <div class="tw-card__head justify-content-end border-top">
        <?= $this->fetch('partial::link', [
            'label'   => $this->t('Cancel'),
            'href'    => $this->url('credential'),
            'classes' => 'btn btn-ghost',
        ]) ?>
        <?= $this->fetch('partial::input/button', [
            'label' => $this->t('Save changes'),
            'icon'  => 'bi bi-check-lg',
        ]) ?>
    </div>
</form>

<section class="mt-4">
    <div class="tw-card">
        <div class="tw-card__head">
            <h2><?= $this->e($this->t('Servers using this credential')) ?></h2>
        </div>
        <?php if ($servers === []): ?>
            <div class="tw-card__body text-muted-2" style="font-size:.85rem">
                <?= $this->e($this->t('No servers are using this credential.')) ?>
            </div>
        <?php else: ?>
            <div class="tw-table-wrap">
                <table class="tw-table">
                    <thead>
                    <tr>
                        <th><?= $this->t('Name') ?></th>
                        <th class="tw-hide-sm"><?= $this->t('Host') ?></th>
                    </tr>
                    </thead>
                    <tbody>
                    <?php
                    /** @var \Tragwerk\Domain\Entity\Server $server */
                    foreach ($servers as $server): ?>
                        <tr>
                            <td><span class="tw-cell-strong"><?= $this->fetch('partial::link', [
                                    'href'  => $this->url('server.show', ['id' => $server->id->toString()]),
                                    'label' => $server->name,
                                    ]) ?></span></td>
                            <td class="tw-hide-sm"><code><?= $this->e($server->host) ?></code></td>
                        </tr>
                    <?php endforeach ?>
                    </tbody>
                </table>
            </div>
        <?php endif ?>
    </div>
</section>

<section id="danger" class="mt-4">
    <div class="tw-card" style="border-color:var(--danger-soft)">
        <div class="tw-card__head" style="border-color:var(--danger-soft)">
            <h2 style="color:var(--danger-text)"><?= $this->e($this->t('Danger zone')) ?></h2>
        </div>
        <div class="tw-card__body d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <div class="fw-semibold" style="font-size:.92rem"><?= $this->e($this->t('Delete credential')) ?></div>
                <div class="text-muted-2" style="font-size:.82rem">
                    <?= $isAssigned
                        ? $this->e($this->t('This credential is assigned to one or more servers and cannot be deleted.'))
                        : $this->e($this->t('Permanently removes the credential.')) ?>
                </div>
            </div>
            <?php if ($isAssigned): ?>
                <button type="button" class="btn btn-outline-secondary" disabled
                        title="<?= $this->e($this->t('Cannot delete: credential is assigned to servers')) ?>">
                    <i class="bi bi-trash3"></i> <?= $this->e($this->t('Delete credential')) ?>
                </button>
            <?php else: ?>
                <button type="button" class="btn btn-outline-secondary"
                        style="color:var(--danger-text);border-color:var(--danger-soft)"
                        data-bs-toggle="modal" data-bs-target="#tw-delete-credential-modal">
                    <i class="bi bi-trash3"></i> <?= $this->e($this->t('Delete credential')) ?>
                </button>
            <?php endif ?>
        </div>
    </div>
</section>

<?php if (! $isAssigned): ?>
    <?= $this->fetch('partial::modal', [
        'id'            => 'tw-delete-credential-modal',
        'header'        => $this->t('Delete credential'),
        'body'          => $this->t('Are you sure you want to delete the credential {name}? This action cannot be undone.', ['name' => '<strong>' . $this->e($credential->name) . '</strong>']),
        'actionUrl'     => $this->url('credential.delete', ['id' => $credential->id->toString()]),
        'actionLabel'   => $this->t('Delete credential'),
        'actionClasses' => 'btn btn-danger',
        'actionIcon'    => 'bi bi-trash3',
    ]) ?>
<?php endif ?>
