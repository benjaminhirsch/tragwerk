<?php $this->layout('layout::default', ['title' => _('Edit credential')]) ?>

<h1><?= _('Edit credential') ?></h1>

<?php $this->start('card-content') ?>
    <form action="<?= $this->url('credential.edit', ['id' => $credential->id->toString()]) ?>" method="post">
        <?= $this->fetch('partial::input/csrf') ?>

        <?= $this->fetch('partial::input/text', [
            'id'         => 'name',
            'label'      => _('Name'),
            'autofocus'  => 'autofocus',
            'validation' => $validationBag,
        ]) ?>

        <?= $this->fetch('partial::input/text', [
            'id'         => 'username',
            'label'      => _('Username'),
            'validation' => $validationBag,
        ]) ?>

        <?= $this->fetch('partial::input/text', [
            'id'         => 'privateKey',
            'label'      => _('Private key'),
            'validation' => $validationBag,
        ]) ?>

        <?php if ($deleteBlocked ?? false): ?>
            <div class="alert alert-danger" role="alert">
                <?= _('This credential is assigned to one or more servers and cannot be deleted. Remove the assignment first.') ?>
            </div>
        <?php elseif ($isAssigned ?? false): ?>
            <div class="alert alert-warning" role="alert">
                <?= _('This credential is currently assigned to one or more servers. Remove the assignment before deleting.') ?>
            </div>
        <?php endif ?>

        <div class="d-flex gap-2">
            <?= $this->fetch('partial::input/button', [
                'label' => _('Save'),
            ]) ?>
            <?= $this->fetch('partial::link', [
                'label'   => _('Cancel'),
                'href'    => $this->url('credential'),
                'classes' => 'btn btn-secondary',
            ]) ?>
            <?php if (! ($isAssigned ?? false)): ?>
                <?= $this->fetch('partial::input/button', [
                    'classes'      => 'btn btn-outline-danger',
                    'icon'         => 'bi bi-trash3',
                    'type'         => 'button',
                    'dataBsToggle' => 'modal',
                    'dataBsTarget' => '#tw-delete-credential-modal',
                ]) ?>
            <?php endif ?>
        </div>
    </form>
<?php $this->stop() ?>

<?= $this->fetch('partial::modal', [
    'id'            => 'tw-delete-credential-modal',
    'header'        => _('Delete credential'),
    'body'          => sprintf(_('Are you sure you want to delete the credential %s? This action cannot be undone.'), '<strong>' . $this->e($credential->name) . '</strong>'),
    'actionUrl'     => $this->url('credential.delete', ['id' => $credential->id->toString()]),
    'actionLabel'   => _('Delete credential'),
    'actionClasses' => 'btn btn-danger',
    'actionIcon'    => 'bi bi-trash3',
]) ?>
