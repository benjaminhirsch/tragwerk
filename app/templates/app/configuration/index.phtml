<?php
/** Humanize a runtime enum value such as "php:8.5" → "PHP 8.5". */
$runtimeLabel = static fn(string $value): string => ucfirst(str_replace(':', ' ', $value));

/** Slugify a name the same way DockerComposeGenerator does (for volume names). */
$slugify = static function (string $name): string {
    $slug = preg_replace('/[\s_]+/', '-', strtolower($name)) ?? '';

    return preg_replace('/[^a-z0-9-]/', '', $slug) ?? '';
};

$app = null;
if ($projectConfig !== null && $projectConfig->applications !== []) {
    $app = $projectConfig->applications[0];
    assert($app instanceof ApplicationConfig);
}

// Resolve a route pattern's {placeholder} to its effective host(s) for this
// environment. $hostsByPlaceholder already applies explicit-wins and wildcard
// subdomain derivation (DomainResolver), so just join the resolved hosts.
$resolveDomain = static function (string $pattern) use ($hostsByPlaceholder): string|null {
    if (preg_match('/\{([a-z0-9_-]+)\}/i', $pattern, $matches) !== 1) {
        return null;
    }

    $hosts = $hostsByPlaceholder[$matches[1]] ?? [];

    return $hosts === [] ? null : implode(', ', $hosts);
};
?>

