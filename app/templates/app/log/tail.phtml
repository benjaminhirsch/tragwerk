<?php

declare(strict_types=1);

/**
 * @var string                                                                              $branch
 * @var string                                                                              $service
 * @var list<array{time: string, level: string, logger: string, msg: string, raw: string}> $entries
 * @var string|null                                                                         $error
 */

$lineClass = static fn (string $level): string => match ($level) {
    'error', 'fatal', 'panic' => 'l-err',
    'warn', 'warning'         => 'l-warn',
    'info'                    => 'l-info',
    'debug', 'trace'          => 'l-dim',
    default                   => 'l-txt',
};
?>
<div class="log-tail__inner term-win"
     hx-get="<?= $this->e($this->url('log.tail') . '?service=' . urlencode($service ?? '')) ?>"
     hx-trigger="every 10s, sse:message"
     hx-target="#log-tail"
     hx-swap="innerHTML">

    <div class="term-bar">
        <span class="term-title"><?= $this->e($service ?? '') ?></span>
        <span class="term-actions tw-cell-muted" style="font-size:.74rem">
            <?= count($entries) ?> <?= $this->e($this->t('entries')) ?> &middot; <?= $this->e($this->t('last 500 lines')) ?>
        </span>
    </div>

    <div class="term-body">
        <?php if ($error !== null): ?>
            <div class="ln l-warn"><span class="l-txt"><?= $this->e($error) ?></span></div>
        <?php elseif ($entries === []): ?>
            <div class="ln l-dim"><span class="l-txt"><?= $this->e($this->t('No log entries.')) ?></span></div>
        <?php else: ?>
            <?php foreach ($entries as $entry): ?>
                <div class="ln">
                    <span class="lt"><?= $this->e($entry['time']) ?></span>
                    <span class="<?= $lineClass($entry['level']) ?>" style="flex:none;text-transform:uppercase"><?= $this->e($entry['level']) ?></span>
                    <?php if ($entry['logger'] !== ''): ?>
                        <span class="l-dim" style="flex:none"><?= $this->e($entry['logger']) ?></span>
                    <?php endif ?>
                    <span class="l-txt"><?= $this->e($entry['msg']) ?></span>
                </div>
            <?php endforeach ?>
        <?php endif ?>
    </div>
</div>
