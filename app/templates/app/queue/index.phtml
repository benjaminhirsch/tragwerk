<?php
/** @var \Tragwerk\Domain\Entity\QueueMessage[] $messages */
$this->layout('layout::default', ['title' => $this->t('Queue Messages')]);

$statusLabel = static function (\Tragwerk\Domain\Entity\QueueMessage $m): string {
    if ($m->isFailed()) {
        return '<span class="badge bg-danger">' . $this->t('Failed') . '</span>';
    }

    if ($m->isBeingProcessed()) {
        return '<span class="badge bg-warning text-dark">' . $this->t('Processing') . '</span>';
    }

    return '<span class="badge bg-secondary">' . $this->t('Pending') . '</span>';
};
?>

<h1><?= $this->t('Queue Messages') ?></h1>

<div class="tw-card">
    <table class="table table-striped table-hover">
        <thead>
        <tr>
            <th><?= $this->t('Type') ?></th>
            <th><?= $this->t('Queue') ?></th>
            <th><?= $this->t('Status') ?></th>
            <th><?= $this->t('Redelivered') ?></th>
            <th><?= $this->t('Published') ?></th>
            <th><?= $this->t('Actions') ?></th>
        </tr>
        </thead>
        <tbody>
        <?php if ($messages === []): ?>
            <tr>
                <td colspan="6" class="text-center text-secondary"><?= $this->t('No messages in queue') ?></td>
            </tr>
        <?php else: ?>
            <?php foreach ($messages as $message): ?>
                <tr>
                    <td>
                        <?= $this->fetch('partial::link', [
                            'href'  => $this->url('queue.show', ['id' => $message->id]),
                            'label' => $message->getMessageType(),
                        ]) ?>
                    </td>
                    <td>
                        <span class="badge <?= $message->isFailed() ? 'bg-danger' : 'bg-primary' ?>">
                            <?= $this->e($message->queue) ?>
                        </span>
                    </td>
                    <td><?= $statusLabel($message) ?></td>
                    <td>
                        <?php if ($message->redelivered): ?>
                            <i class="bi bi-arrow-repeat text-warning"></i>
                        <?php else: ?>
                            <i class="bi bi-dash text-secondary"></i>
                        <?php endif ?>
                    </td>
                    <td>
                        <?= $this->e(date('Y-m-d H:i:s', intdiv($message->publishedAt, 1000))) ?>
                    </td>
                    <td>
                        <?php if ($message->isFailed()): ?>
                            <div class="d-flex gap-2">
                                <form method="post" action="<?= $this->url('queue.requeue', ['id' => $message->id]) ?>">
                                    <?= $this->fetch('partial::input/csrf') ?>
                                    <?= $this->fetch('partial::input/button', [
                                        'label'   => $this->t('Requeue'),
                                        'classes' => 'btn btn-sm btn-warning',
                                        'icon'    => 'bi bi-arrow-clockwise',
                                    ]) ?>
                                </form>
                                <?= $this->fetch('partial::input/button', [
                                    'label'        => $this->t('Delete'),
                                    'classes'      => 'btn btn-sm btn-outline-danger',
                                    'icon'         => 'bi bi-trash3',
                                    'type'         => 'button',
                                    'dataBsToggle' => 'modal',
                                    'dataBsTarget' => '#tw-delete-queue-modal-' . $this->e($message->id),
                                ]) ?>
                            </div>
                        <?php else: ?>
                            <span class="text-secondary">—</span>
                        <?php endif ?>
                    </td>
                </tr>
            <?php endforeach ?>
        <?php endif ?>
        </tbody>
    </table>
</div>

<?php foreach ($messages as $message): ?>
    <?php if ($message->isFailed()): ?>
        <?= $this->fetch('partial::modal', [
            'id'            => 'tw-delete-queue-modal-' . $message->id,
            'header'        => $this->t('Delete queue message'),
            'body'          => $this->t('Are you sure you want to delete the message {name}? This action cannot be undone.', ['name' => '<strong>' . $this->e($message->getMessageType()) . '</strong>']),
            'actionUrl'     => $this->url('queue.delete', ['id' => $message->id]),
            'actionLabel'   => $this->t('Delete'),
            'actionClasses' => 'btn btn-danger',
            'actionIcon'    => 'bi bi-trash3',
        ]) ?>
    <?php endif ?>
<?php endforeach ?>
