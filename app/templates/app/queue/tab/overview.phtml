<?php
/** @var \Tragwerk\Domain\Entity\QueueMessage $message */
?>
<table class="table table-borderless mb-0">
    <tbody>
        <tr>
            <th class="w-25 text-body-secondary fw-normal"><?= _('ID') ?></th>
            <td><code><?= $this->e($message->id) ?></code></td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= _('Type') ?></th>
            <td><code><?= $this->e($message->getMessageType()) ?></code></td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= _('Queue') ?></th>
            <td>
                <span class="badge <?= $message->isFailed() ? 'bg-danger' : 'bg-primary' ?>">
                    <?= $this->e($message->queue) ?>
                </span>
            </td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= _('Status') ?></th>
            <td>
                <?php if ($message->isFailed()): ?>
                    <span class="badge bg-danger"><?= _('Failed') ?></span>
                <?php elseif ($message->isBeingProcessed()): ?>
                    <span class="badge bg-warning text-dark"><?= _('Processing') ?></span>
                <?php else: ?>
                    <span class="badge bg-secondary"><?= _('Pending') ?></span>
                <?php endif ?>
            </td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= _('Redelivered') ?></th>
            <td>
                <?php if ($message->redelivered): ?>
                    <i class="bi bi-arrow-repeat text-warning"></i> <?= _('Yes') ?>
                <?php else: ?>
                    <span class="text-body-secondary">—</span>
                <?php endif ?>
            </td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= _('Priority') ?></th>
            <td>
                <?= $message->priority !== null ? $this->e((string) $message->priority) : '<span class="text-body-secondary">—</span>' ?>
            </td>
        </tr>
        <tr>
            <th class="text-body-secondary fw-normal"><?= _('Published') ?></th>
            <td><?= $this->e(date('Y-m-d H:i:s', intdiv($message->publishedAt, 1000))) ?></td>
        </tr>
        <?php if ($message->deliveryId !== null): ?>
        <tr>
            <th class="text-body-secondary fw-normal"><?= _('Delivery ID') ?></th>
            <td><code><?= $this->e($message->deliveryId) ?></code></td>
        </tr>
        <?php endif ?>
    </tbody>
</table>
