<?php
/** @var \Tragwerk\Domain\Entity\QueueMessage $message */
$decoded = json_decode($message->body, true);
$formatted = $decoded !== null
    ? json_encode($decoded, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES)
    : $message->body;
?>
<pre class="mb-0" style="max-height: 600px; overflow-y: auto;"><code><?= $this->e($formatted !== false ? $formatted : $message->body) ?></code></pre>
