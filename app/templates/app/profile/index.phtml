<?php
/**
 * @var \Tragwerk\Domain\Entity\SshKey[]              $keys
 * @var \Tragwerk\Application\Validation\ValidationBag|null $validationBag
 */
$this->layout('layout::default', ['title' => _('Profile')]);
?>

<h1><?= _('Profile') ?></h1>

<?php $this->start('card-content') ?>
    <h2 class="h5 mb-3"><?= _('SSH Keys') ?></h2>

    <?php if ($keys !== []): ?>
        <table class="table table-borderless mb-4">
            <thead>
                <tr>
                    <th><?= _('Name') ?></th>
                    <th><?= _('Added') ?></th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($keys as $key): ?>
                    <tr>
                        <td class="align-middle">
                            <i class="bi bi-key me-1 text-body-secondary"></i>
                            <?= $this->e($key->name) ?>
                        </td>
                        <td class="align-middle text-body-secondary">
                            <?= $this->e($key->createdAt->format('Y-m-d')) ?>
                        </td>
                        <td class="text-end">
                            <form method="post"
                                  action="<?= $this->url('profile') ?>"
                                  onsubmit="return confirm('<?= _('Remove this SSH key?') ?>')">
                                <?= $this->fetch('partial::input/csrf') ?>
                                <input type="hidden" name="action" value="delete">
                                <input type="hidden" name="keyId" value="<?= $this->e($key->id->toString()) ?>">
                                <?= $this->fetch('partial::input/button', [
                                    'classes' => 'btn btn-outline-danger btn-sm',
                                    'icon'    => 'bi bi-trash3',
                                ]) ?>
                            </form>
                        </td>
                    </tr>
                <?php endforeach ?>
            </tbody>
        </table>
    <?php else: ?>
        <p class="text-body-secondary mb-4"><?= _('No SSH keys added yet.') ?></p>
    <?php endif ?>

    <h3 class="h6 mb-3"><?= _('Add SSH key') ?></h3>
    <form method="post" action="<?= $this->url('profile') ?>">
        <?= $this->fetch('partial::input/csrf') ?>
        <input type="hidden" name="action" value="create">

        <?= $this->fetch('partial::input/text', [
            'id'         => 'name',
            'label'      => _('Name'),
            'validation' => $validationBag,
        ]) ?>

        <?= $this->fetch('partial::input/textarea', [
            'id'          => 'publicKey',
            'label'       => _('Public key'),
            'placeholder' => 'ssh-ed25519 AAAA...',
            'rows'        => 4,
            'validation'  => $validationBag,
        ]) ?>

        <?= $this->fetch('partial::input/button', [
            'label' => _('Add key'),
            'icon'  => 'bi bi-plus-lg',
        ]) ?>
    </form>
<?php $this->stop() ?>
