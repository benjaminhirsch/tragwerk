<?php
/**
 * @var \Tragwerk\Domain\Entity\SshKey[]              $keys
 * @var \Tragwerk\Application\Validation\ValidationBag|null $validationBag
 */
$this->layout('layout::default', ['title' => $this->t('Profile')]);
?>

<h1><?= $this->t('Profile') ?></h1>

<?php $this->start('card-content') ?>
    <h2 class="h5 mb-3"><?= $this->t('SSH Keys') ?></h2>

    <?php if ($keys !== []): ?>
        <table class="table table-borderless mb-4">
            <thead>
                <tr>
                    <th><?= $this->t('Name') ?></th>
                    <th><?= $this->t('Added') ?></th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($keys as $key): ?>
                    <tr>
                        <td class="align-middle">
                            <i class="bi bi-key me-1 text-body-secondary"></i>
                            <?= $this->e($key->name) ?>
                        </td>
                        <td class="align-middle text-body-secondary">
                            <?= $this->e($key->createdAt->format('Y-m-d')) ?>
                        </td>
                        <td class="text-end">
                            <?= $this->fetch('partial::input/button', [
                                'classes'      => 'btn btn-outline-danger btn-sm',
                                'icon'         => 'bi bi-trash3',
                                'type'         => 'button',
                                'dataBsToggle' => 'modal',
                                'dataBsTarget' => '#tw-delete-key-modal-' . $key->id->toString(),
                            ]) ?>
                        </td>
                    </tr>
                <?php endforeach ?>
            </tbody>
        </table>

    <?php else: ?>
        <p class="text-body-secondary mb-4"><?= $this->t('No SSH keys added yet.') ?></p>
    <?php endif ?>

    <h3 class="h6 mb-3"><?= $this->t('Add SSH key') ?></h3>
    <form method="post" action="<?= $this->url('profile') ?>">
        <?= $this->fetch('partial::input/csrf') ?>
        <input type="hidden" name="action" value="create">

        <?= $this->fetch('partial::input/text', [
            'id'         => 'name',
            'label'      => $this->t('Name'),
            'validation' => $validationBag,
        ]) ?>

        <?= $this->fetch('partial::input/textarea', [
            'id'          => 'publicKey',
            'label'       => $this->t('Public key'),
            'placeholder' => 'ssh-ed25519 AAAA...',
            'rows'        => 4,
            'validation'  => $validationBag,
        ]) ?>

        <?= $this->fetch('partial::input/button', [
            'label' => $this->t('Add key'),
            'icon'  => 'bi bi-plus-lg',
        ]) ?>
    </form>
<?php $this->stop() ?>

<?php foreach ($keys as $key): ?>
    <?= $this->fetch('partial::modal', [
        'id'            => 'tw-delete-key-modal-' . $key->id->toString(),
        'header'        => $this->t('Delete SSH key'),
        'body'          => $this->t('Are you sure you want to delete the SSH key {name}? This action cannot be undone.', ['name' => '<strong>' . $this->e($key->name) . '</strong>']),
        'actionUrl'     => $this->url('profile'),
        'actionLabel'   => $this->t('Delete key'),
        'actionClasses' => 'btn btn-danger',
        'actionIcon'    => 'bi bi-trash3',
        'extraFields'   => ['action' => 'delete', 'keyId' => $key->id->toString()],
    ]) ?>
<?php endforeach ?>
