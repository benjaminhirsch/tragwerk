<?php
$statusBadge = static function (?DeployJobStatus $status): array {
    return match ($status) {
        DeployJobStatus::Completed => ['tw-badge--ok', 'Active'],
        DeployJobStatus::Failed    => ['tw-badge--danger', 'Failed'],
        DeployJobStatus::Running   => ['tw-badge--building', 'Deploying'],
        DeployJobStatus::Pending   => ['tw-badge--neutral', 'Pending'],
        default                    => ['tw-badge--neutral', 'Never deployed'],
    };
};
?>

<?= $this->fetch('partial::card/container', $cards) ?>

