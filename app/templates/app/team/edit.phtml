<?php

/** @var \Tragwerk\Domain\Entity\Team $team */
/** @var \Tragwerk\Application\Validation\ValidationBag $validationBag */
/** @var \Tragwerk\Domain\ValueObject\TeamMembership[] $memberships */
/** @var \Tragwerk\Domain\Entity\TeamInvitation[] $pendingInvitations */
/** @var bool $canManage */
/** @var bool $actorIsOwner */
/** @var bool $canDelete */

$this->layout('layout::default', [
    'wide'         => true,
    'pageType'     => $this->activeTeam()->name,
    'pageTitle'    => $this->t('Settings'),
    'pageSubTitle' => $this->t('Team-wide configuration, members and access.'),
]);

$nameError = $validationBag->getErrorByName('name');
?>

<form action="<?= $this->url('team.edit', ['id' => $team->id->toString()]) ?>" method="post">
    <?= $this->fetch('partial::input/csrf') ?>

    <!-- General -->
    <section id="general" class="mb-4">
        <div class="tw-card">
            <div class="tw-card__head"><h2><?= $this->e($this->t('General')) ?></h2></div>
            <div class="tw-card__body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="name"><?= $this->e($this->t('Team name')) ?></label>
                        <input id="name" name="name" type="text" autofocus
                               class="form-control<?= $nameError !== null ? ' is-invalid' : '' ?>"
                               value="<?= $this->e($validationBag->getValueByName('name')) ?>">
                        <?php if ($nameError !== null): ?>
                            <div class="invalid-feedback d-block"><?= $this->e($this->t($nameError)) ?></div>
                        <?php endif ?>
                    </div>
                </div>
            </div>
            <div class="tw-card__head" style="border-top:1px solid var(--border);border-bottom:none;justify-content:flex-end;gap:.6rem">
                <a href="<?= $this->url('team.show', ['id' => $this->activeTeam()->id]) ?>" class="btn btn-ghost"><?= $this->e($this->t('Cancel')) ?></a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> <?= $this->e($this->t('Save changes')) ?></button>
            </div>
        </div>
    </section>

    <!-- Members -->
    <section id="members" class="mb-4">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <div>
                <h2 style="font-size:1.1rem;margin:0"><?= $this->e($this->t('Members')) ?></h2>
                <p class="text-faint m-0" style="font-size:.82rem"><?= $this->e($this->t('Members of this team. The owner cannot be removed.')) ?></p>
            </div>
        </div>

        <?= $this->fetch('partial::team/members-manage', [
            'memberships'        => $memberships,
            'pendingInvitations' => $pendingInvitations,
            'teamId'             => $team->id->toString(),
            'canManage'          => $canManage,
            'actorIsOwner'       => $actorIsOwner,
            'emails'             => $validationBag->getArrayValueByName('emailsToInvite') ?: [''],
            'roles'              => $validationBag->getArrayValueByName('rolesToInvite') ?: [],
            'validation'         => $validationBag,
        ]) ?>
    </section>
</form>

<!-- Danger zone -->
<?php if ($canDelete): ?>
    <section id="danger">
        <div class="tw-card" style="border-color:var(--danger-soft)">
            <div class="tw-card__head" style="border-color:var(--danger-soft)">
                <h2 style="color:var(--danger-text)"><?= $this->e($this->t('Danger zone')) ?></h2>
            </div>
            <div class="tw-card__body d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <div class="fw-semibold" style="font-size:.92rem"><?= $this->e($this->t('Delete team')) ?></div>
                    <div class="text-muted-2" style="font-size:.82rem"><?= $this->e($this->t('Permanently removes the team and all associated resources.')) ?></div>
                </div>
                <button type="button" class="btn btn-outline-secondary"
                        style="color:var(--danger-text);border-color:var(--danger-soft)"
                        data-bs-toggle="modal" data-bs-target="#tw-delete-team-modal">
                    <i class="bi bi-trash3"></i> <?= $this->e($this->t('Delete team')) ?>
                </button>
            </div>
        </div>
    </section>

    <?= $this->fetch('partial::modal', [
        'id'            => 'tw-delete-team-modal',
        'header'        => $this->t('Delete team'),
        'body'          => $this->t('Are you sure you want to delete the team {name}? This action cannot be undone. Deleting a team will delete all associated resources too!', ['name' => '<strong>' . $this->e($team->name) . '</strong>']),
        'actionUrl'     => $this->url('team.delete', ['id' => $team->id->toString()]),
        'actionLabel'   => $this->t('Delete team'),
        'actionClasses' => 'btn btn-danger',
        'actionIcon'    => 'bi bi-trash3',
    ]) ?>
<?php endif ?>
