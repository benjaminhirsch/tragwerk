<?php $this->layout('layout::default', ['title' => $this->t('Add registry')]) ?>

<h1><?= $this->t('Add registry') ?></h1>

<?php $this->start('card-content') ?>
    <form action="<?= $this->url('registry.create') ?>" method="post">
        <?= $this->fetch('partial::input/csrf') ?>
        <?= $this->fetch('partial::input/text', [
            'id'        => 'name',
            'label'     => $this->t('Name'),
            'autofocus' => 'autofocus',
            'validation' => $validationBag ?? null,
        ]) ?>
        <?= $this->fetch('partial::input/text', [
            'id'          => 'url',
            'label'       => $this->t('Registry URL'),
            'placeholder' => 'docker.io',
            'validation'  => $validationBag ?? null,
        ]) ?>
        <?= $this->fetch('partial::input/text', [
            'id'          => 'repository',
            'label'       => $this->t('Repository'),
            'placeholder' => 'benjaminhirsch/myapp',
            'validation'  => $validationBag ?? null,
        ]) ?>
        <?= $this->fetch('partial::input/text', [
            'id'         => 'username',
            'label'      => $this->t('Username'),
            'validation' => $validationBag ?? null,
        ]) ?>
        <?= $this->fetch('partial::input/text', [
            'id'         => 'password',
            'label'      => $this->t('Password / Token'),
            'type'       => 'password',
            'validation' => $validationBag ?? null,
        ]) ?>
        <hr>
        <p class="text-body-secondary small mb-2">
            <?= $this->t('Image pruning is supported for Docker Hub (<code>docker.io</code>) and OCI-compatible registries. AWS ECR, Azure ACR and Quay.io are not supported.') ?>
        </p>
        <div class="mb-3 form-check">
            <input type="checkbox" class="form-check-input" id="pruningEnabled" name="pruningEnabled" value="1">
            <label class="form-check-label" for="pruningEnabled">
                <?= $this->t('Enable image pruning after deploy') ?>
            </label>
        </div>
        <?= $this->fetch('partial::input/text', [
            'id'    => 'keepTags',
            'name'  => 'keepTags',
            'label' => $this->t('Tags to keep'),
            'value' => '10',
            'validation' => $validationBag ?? null,
        ]) ?>
        <div class="d-flex gap-2">
            <?= $this->fetch('partial::input/button', ['label' => $this->t('Save')]) ?>
            <?= $this->fetch('partial::link', [
                'label'   => $this->t('Cancel'),
                'href'    => $this->url('registry'),
                'classes' => 'btn btn-secondary',
            ]) ?>
        </div>
    </form>
<?php $this->stop() ?>
