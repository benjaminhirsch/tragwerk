<?php

$this->layout('layout::default', [
        'pageType' =>  $this->activeTeam()->name,
        'pageTitle' => $this->t('Container Registries'),
        'pageSubTitle' => $this->t('Private and public image registries for the team.'),
]) ?>

<?php $this->start('pageHeadButtons') ?>
<?= $this->fetch('partial::link', [
        'label'   => $this->t('Add registry'),
        'icon'    => 'bi bi-plus-circle',
        'classes' => 'btn btn-primary',
        'href'    => $this->url('registry.create'),
]) ?>
<?php $this->stop() ?>

<div class="tw-table-wrap">
        <table class="tw-table">
            <thead>
                <tr>
                    <th class="sortable"><?= $this->t('Name') ?></th>
                    <th class="sortable"><?= $this->t('URL') ?></th>
                    <th class="sortable"><?= $this->t('Username') ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($registries as $registry): ?>
                    <tr>
                        <td>
                            <?= $this->fetch('partial::link', [
                                'href'  => $this->url('registry.edit', ['id' => $registry->id->toString()]),
                                'label' => $registry->name,
                            ]) ?>
                        </td>
                        <td><?= $this->e($registry->url) ?></td>
                        <td><?= $this->e($registry->username) ?></td>
                    </tr>
                <?php endforeach ?>
                <?php if ($registries === []): ?>
                    <tr>
                        <td class="text-center" colspan="3">
                            <?= $this->t('No registries configured yet. Add a container registry to enable image-based deployments.') ?>
                        </td>
                    </tr>
                <?php endif; ?>
            </tbody>
        </table>

</div>
