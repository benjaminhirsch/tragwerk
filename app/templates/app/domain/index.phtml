<?php

declare(strict_types=1);

/**
 * @var string                                 $branch
 * @var list<\Tragwerk\Domain\Entity\Domain>   $domains
 */

$this->layout('layout::default', [
    'pageType' =>  $this->activeTeam()->name . ' / ' . $this->activeEnvironment(),
    'pageTitle' => $this->t('Domains'),
    'pageSubTitle' => $this->t('Connect custom domains and map them to a routing placeholder.'),
]) ?>

<?php $this->start('pageHeadButtons') ?>
<?= $this->fetch('partial::link', [
    'label'   => $this->t('Add domain'),
    'href'    => $this->url('domain.create'),
    'icon'    => 'bi bi-plus-lg',
    'classes' => 'btn btn-primary',
]) ?>
<?php $this->stop() ?>

<div class="tw-table-wrap">
    <table class="tw-table">
        <thead>
        <tr>
            <th><?= $this->e($this->t('Domain')) ?></th>
            <th><?= $this->e($this->t('Target placeholder')) ?></th>
            <th><?= $this->e($this->t('Primary')) ?></th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        <?php
        /** @var \Tragwerk\Domain\Entity\Domain $domain */
        foreach ($domains as $domain): ?>
            <tr>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-globe2" style="color:var(--text-faint)"></i>
                        <?= $this->fetch('partial::link', [
                            'label'   => $domain->host,
                            'href'    => sprintf('https://%s', $domain->host),
                            'target'  => '_blank',
                            'classes' => 'tw-cell-strong mono',
                        ]) ?>
                    </div>
                </td>
                <td><span class="tw-badge tw-badge--neutral mono">{<?= $this->e($domain->placeholder) ?>}</span></td>
                <td>
                    <?php if ($domain->isPrimary): ?>
                        <span class="tw-badge tw-badge--info"><i class="bi bi-star-fill" style="font-size:.7rem"></i><?= $this->e($this->t('Primary')) ?></span>
                    <?php else: ?>
                        <form action="<?= $this->url('domain.primary', ['domainId' => $domain->id->toString()]) ?>" method="post">
                            <?= $this->fetch('partial::input/csrf') ?>
                            <button type="submit" class="btn btn-ghost btn-sm"><?= $this->e($this->t('Set as primary')) ?></button>
                        </form>
                    <?php endif ?>
                </td>
                <td class="text-end">
                    <div class="d-flex justify-content-end gap-1">
                        <button class="btn btn-ghost btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#tw-delete-domain-<?= $this->e($domain->id->toString()) ?>" title="<?= $this->e($this->t('Remove')) ?>"><i class="bi bi-trash3"></i></button>
                    </div>
                </td>
            </tr>
        <?php endforeach ?>
        </tbody>
    </table>
</div>

<p class="text-muted-2 mt-2" style="font-size:.8rem">
    <i class="bi bi-info-circle" style="color:var(--accent-text)"></i>
    <?= $this->e($this->t('Exactly one primary domain is allowed — it is used for absolute links and redirects. Point a CNAME/A record at the server; SSL certificates are issued automatically.')) ?>
</p>

<?php
/** @var \Tragwerk\Domain\Entity\Domain $domain */
foreach ($domains as $domain):
    $body = $this->t('Are you sure you want to remove {host}? It will no longer be routed to this project.', ['host' => '<b class="mono">' . $this->e($domain->host) . '</b>']);
    if ($domain->isPrimary) {
        $body .= '<br><br>' . $this->t('This is the primary domain. After removal, another domain will be set as primary automatically.');
    }
    ?>
    <?= $this->fetch('partial::modal', [
        'id'            => 'tw-delete-domain-' . $domain->id->toString(),
        'header'        => $this->t('Remove domain'),
        'body'          => $body,
        'actionUrl'     => $this->url('domain.delete', ['domainId' => $domain->id->toString()]),
        'actionLabel'   => $this->t('Remove'),
        'actionClasses' => 'btn btn-danger',
        'actionIcon'    => 'bi bi-trash3',
    ]) ?>
<?php endforeach ?>
