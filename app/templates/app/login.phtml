    <form class="auth-form" action="<?= $this->url('login') ?>" method="post">
    <?= $this->fetch('partial::input/csrf') ?>

        <?php if ($registered ?? false): ?>
            <div class="alert alert-info small mb-3">
                <?= $this->t('Registration successful. Please check your email to confirm your account.') ?>
            </div>
        <?php endif ?>

        <?php if ($confirmed ?? false): ?>
            <div class="alert alert-success small mb-3">
                <?= $this->t('Your email address has been confirmed. You can now sign in.') ?>
            </div>
        <?php endif ?>

        <?php if ($resetRequested ?? false): ?>
            <div class="alert alert-info small mb-3">
                <?= $this->t('If an account exists for that email, a password reset link has been sent.') ?>
            </div>
        <?php endif ?>

        <?php if ($passwordReset ?? false): ?>
            <div class="alert alert-success small mb-3">
                <?= $this->t('Your password has been updated. You can now sign in with your new password.') ?>
            </div>
        <?php endif ?>

        <?php if ($notConfirmed ?? false): ?>
            <div class="alert alert-warning small mb-3">
                <?= $this->t('Please confirm your email address before signing in. Check your inbox for the confirmation link.') ?>
            </div>
        <?php endif ?>

        <?php if ($loginError ?? false): ?>
            <?= $this->fetch('partial::alert', [
                    'content' => $this->t('Invalid email address or password.'),
                    'type' => 'danger',
            ]) ?>
        <?php endif ?>


            <?= $this->fetch('partial::input/email', [
                    'id' => 'email',
                    'placeholder' => 'your@email.address',
