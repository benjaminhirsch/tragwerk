<?php

/** @var \Tragwerk\Application\Validation\ValidationBag|null $validationBag */

$this->layout('layout::default', [
    'wide' => false,
    'pageType' => $this->activeTeam()->name . ' / ' . $this->activeEnvironment(),
    'pageTitle' => $this->t('New variable'),
    'pageSubTitle' => $this->t('Injected into the environment at build and runtime.'),
]) ?>

<?php
    $keyError       = $validationBag?->getErrorByName('key');
    $valueError     = $validationBag?->getErrorByName('value');
    $secretChecked  = ($validationBag?->getValueByName('isSecret') ?? '') === '1';
    $inheritedCheck = ($validationBag?->getValueByName('isInherited') ?? '') === '1';
?>

<form action="<?= $this->url('variable.create') ?>" method="post" class="tw-card">
    <div class="tw-card__body d-flex flex-column gap-3">
        <?= $this->fetch('partial::input/csrf') ?>

        <div>
            <label class="form-label" for="key"><?= $this->t('Key') ?></label>
            <input id="key" name="key" type="text" autocomplete="off" autofocus
                   class="form-control key-input<?= $keyError !== null ? ' is-invalid' : '' ?>"
                   placeholder="<?= $this->e($this->t('e.g. DATABASE_URL')) ?>"
                   value="<?= $this->e($validationBag?->getValueByName('key') ?? '') ?>">
            <div class="field-help"><?= $this->t('Uppercase letters, digits and underscores.') ?></div>
            <?php if ($keyError !== null): ?>
                <div class="invalid-feedback d-block"><?= $this->e($this->t($keyError)) ?></div>
            <?php endif ?>
        </div>

        <div>
            <label class="form-label" for="value"><?= $this->t('Value') ?></label>
            <textarea id="value" name="value" rows="3"
                      class="form-control mono<?= $valueError !== null ? ' is-invalid' : '' ?>"
                      style="font-size:.85rem"
                      placeholder="<?= $this->e($this->t('Enter value…')) ?>"><?= $this->e($validationBag?->getValueByName('value') ?? '') ?></textarea>
            <?php if ($valueError !== null): ?>
                <div class="invalid-feedback d-block"><?= $this->e($this->t($valueError)) ?></div>
            <?php endif ?>
        </div>

        <div>
            <div class="prop-switch">
                <input id="isSecret" name="isSecret" value="1" class="form-check-input" type="checkbox"<?= $secretChecked ? ' checked' : '' ?>>
                <div>
                    <label class="ttl d-block" for="isSecret"><?= $this->t('Secret') ?></label>
                    <div class="dsc"><?= $this->t('Value is stored encrypted and masked in the UI and in logs.') ?></div>
                </div>
            </div>
            <div class="prop-switch">
                <input id="isInherited" name="isInherited" value="1" class="form-check-input" type="checkbox"<?= $inheritedCheck ? ' checked' : '' ?>>
                <div>
                    <label class="ttl d-block" for="isInherited"><?= $this->t('Inherited') ?></label>
                    <div class="dsc"><?= $this->t('Automatically passed down to all child environments of this environment.') ?></div>
                </div>
            </div>
        </div>
    </div>

    <div class="tw-card__head" style="border-top:1px solid var(--border);border-bottom:none;justify-content:flex-end;gap:.6rem">
        <a href="<?= $this->url('variable') ?>" class="btn btn-ghost"><?= $this->t('Cancel') ?></a>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> <?= $this->t('Create variable') ?></button>
    </div>
</form>
