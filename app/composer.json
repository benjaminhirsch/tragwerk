{
    "name": "mezzio/mezzio-skeleton",
    "description": "Laminas mezzio skeleton. Begin developing PSR-15 middleware applications in seconds!",
    "type": "project",
    "license": "BSD-3-Clause",
    "keywords": [
        "laminas",
        "mezzio",
        "skeleton",
        "middleware",
        "psr",
        "psr-7",
        "psr-11",
        "psr-15"
    ],
    "homepage": "https://mezzio.dev",
    "support": {
        "docs": "https://docs.mezzio.dev/mezzio/",
        "issues": "https://github.com/mezzio/mezzio-skeleton/issues",
        "source": "https://github.com/mezzio/mezzio-skeleton",
        "rss": "https://github.com/mezzio/mezzio-skeleton/releases.atom",
        "chat": "https://laminas.dev/chat",
        "forum": "https://discourse.laminas.dev"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "laminas/laminas-component-installer": true,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.5.99"
        }
    },
    "extra": {
        "laminas": {
            "component-whitelist": [
                "mezzio/mezzio",
                "mezzio/mezzio-helpers",
                "mezzio/mezzio-router",
                "laminas/laminas-httphandlerrunner",
                "mezzio/mezzio-fastroute",
                "mezzio/mezzio-twigrenderer"
            ]
        }
    },
    "require": {
        "php": "~8.5.0",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-gettext": "*",
        "ext-intl": "*",
        "ext-libxml": "*",
        "ext-session": "*",
        "chypriote/unique-names-generator": "^0.0.4",
        "composer/package-versions-deprecated": "^1.11.99.5",
        "cuyz/valinor": "^2.4",
        "doctrine/dbal": "^4.4",
        "doctrine/migrations": "^3.9",
        "enqueue/dbal": "^0.10.27",
        "enqueue/enqueue": "^0.10.27",
        "gettext/gettext": "^5.7",
        "godruoyi/php-snowflake": "^3.2",
        "laminas/laminas-component-installer": "^2.6 || ^3.5",
        "laminas/laminas-config-aggregator": "^1.18",
        "laminas/laminas-diactoros": "^3.8.0",
        "laminas/laminas-httphandlerrunner": "^2.13",
        "laminas/laminas-i18n": "^2.32",
        "laminas/laminas-servicemanager": "^3.24",
        "laminas/laminas-stdlib": "^3.21",
        "laminas/laminas-translator": "^1.3",
        "league/oauth2-client": "^2.9",
        "mezzio/mezzio": "^3.23.1",
        "mezzio/mezzio-authentication": "^1.13",
        "mezzio/mezzio-authentication-session": "^1.11",
        "mezzio/mezzio-fastroute": "^3.11.0",
        "mezzio/mezzio-helpers": "^5.20",
        "mezzio/mezzio-platesrenderer": "^2.14",
        "mezzio/mezzio-session": "^1.17",
        "mezzio/mezzio-session-cache": "^1.17",
        "monolog/monolog": "^3.10",
        "nette/utils": "^4.1",
        "nyholm/psr7": "^1.8",
        "php-di/invoker": "^2.3",
        "php-http/discovery": "^1.20",
        "phpseclib/phpseclib": "^3.0",
        "psr/simple-cache": "^3.0",
        "ramsey/uuid": "^4.9",
        "symfony/cache": "^7.4",
        "symfony/console": "^7.4",
        "symfony/event-dispatcher": "^8.0",
        "symfony/event-dispatcher-contracts": "^3.6",
        "symfony/expression-language": "^8.0",
        "symfony/lock": "^8.0",
        "symfony/mailer": "^8.0",
        "symfony/process": "^7.4",
        "symfony/translation": "^8.0",
        "symfony/yaml": "^8.0",
        "willdurand/negotiation": "^3.1"
    },
    "require-dev": {
        "brianium/paratest": "^7.20",
        "doctrine/coding-standard": "^14.0",
        "filp/whoops": "^2.15.4",
        "laminas/laminas-development-mode": "^3.15",
        "overtrue/phplint": "^9.7",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.0",
        "roave/security-advisories": "dev-master",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "conflict": {
        "amphp/dns": "<2.4.0",
        "amphp/socket": "<2.3.1",
        "php-di/php-di": "<7.0.9"
    },
    "autoload": {
        "psr-4": {
            "Tragwerk\\": "src/Tragwerk/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TragwerkTest\\": "test/"
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "@development-enable"
        ],
        "post-install-cmd": "@clear-config-cache",
        "post-update-cmd": "@clear-config-cache",
        "development-disable": "laminas-development-mode disable",
        "development-enable": "laminas-development-mode enable",
        "development-status": "laminas-development-mode status",
        "mezzio": "laminas --ansi",
        "check": [
            "@phplint",
            "@cs-check",
            "@phpstan"
        ],
        "phplint": "phplint -c phplint.yml",
        "phpstan": "phpstan",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "static-analysis": "@phpstan",
        "static-analysis-update-baseline": "phpstan --generate-baseline",
        "clear-config-cache": "php bin/clear-config-cache.php",
        "enable-codestandard": "Dealerdirect\\Composer\\Plugin\\Installers\\PHPCodeSniffer\\Plugin::run",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "php -S 0.0.0.0:8080 -t public/"
        ],
        "test": "paratest --processes auto --colors=always",
        "test-coverage": "php -d pcov.enabled=1 paratest --processes auto --passthru-php=\"-d pcov.enabled=1\" --colors=always --coverage-clover clover.xml"
    },
    "scripts-descriptions": {
        "clear-config-cache": "Clears merged config cache. Required for config changes to be applied.",
        "static-analysis": "Run static analysis tool Psalm.",
        "static-analysis-update-baseline": "Run static analysis tool Psalm and update baseline."
    }
}
